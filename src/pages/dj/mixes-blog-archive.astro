---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import Icon from "../../components/Icon.astro";
import { getDjPersonSchema } from "../../utils/dj-schema.js";
import { USECASE_CONFIG, USE_CASE_LABELS } from "../../data/usecase-config";
import Hero from "../../components/Hero.astro";
import heroImg from "../../assets/img/em3f/DSC_2451.jpg";

interface BlogPostData {
   slug: string;
   title: string;
   key: string;
   url: string;
   created_time: string;
   src: string;
   description: string;
   picture: string;
   audio_length: number;
   tags: string[];
   useCases: string[];
   tracklist: string[];
   hasTracklist: boolean;
   heroImage?: string;
}

interface BlogData {
  posts: BlogPostData[];
}

let blogData: BlogData = { posts: [] };

try {
  const imported = await import("../../data/blog-posts.json");
  if (imported && imported.default && Array.isArray(imported.default.posts)) {
    blogData = imported.default as unknown as BlogData;
  }
} catch (e) {
  console.warn('Could not load blog-posts.json:', e);
}

const archivePosts = blogData.posts ? blogData.posts.filter(post => post.hasTracklist).slice(1) : [];

const ITEMS_PER_PAGE = 12;
const totalPages = Math.ceil(archivePosts.length / ITEMS_PER_PAGE);

const useCaseFilter = Astro.url.searchParams.get('useCase');

const searchablePosts = archivePosts.map(post => ({
  slug: post.slug,
  title: post.title,
  picture: post.picture,
  description: post.description?.substring(0, 300) || '',
  tags: post.tags,
  tracklist: post.tracklist || []
}));

const breadcrumbLabel = useCaseFilter 
  ? `Archive - ${USE_CASE_LABELS[useCaseFilter] || useCaseFilter}`
  : 'Mix Archive';

const breadcrumbSegments = [
  { label: "Home", href: "/" },
  { label: "Weekly DJ Mixes", href: "/dj/mixes-weekly" },
  { label: breadcrumbLabel }
];

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-GB', { day: '2-digit', month: '2-digit', year: 'numeric' });
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://holger-kampffmeyer.de/"},
    {"@type": "ListItem", "position": 2, "name": "DJ Hulk", "item": "https://holger-kampffmeyer.de/djhulk-electronic-music/"},
    {"@type": "ListItem", "position": 3, "name": "Mix Archive", "item": "https://holger-kampffmeyer.de/dj/mixes-blog-archive/"}
  ]
};

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "DJ Hulk Weekly Mixes Blog",
  "description": "Weekly electronic music DJ mixes by DJ Hulk with full tracklists. House, Tech House, Deep House, Latin House.",
  "url": "https://holger-kampffmeyer.de/dj/mixes-blog-archive/",
  "image": "https://holger-kampffmeyer.de/img/_81A4010.webp",
  "author": {
    "@type": "Person",
    "name": "DJ Hulk",
    "url": "https://holger-kampffmeyer.de/djhulk-electronic-music"
  },
   "blogPosts": archivePosts.slice(0, 10).map(post => ({
     "@type": "BlogPosting",
     "@id": `https://holger-kampffmeyer.de/dj/mixes/${post.slug}`,
      "headline": post.title,
     "datePublished": post.created_time
   }))
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "DJ Hulk Mix Archive",
  "description": "Complete archive of DJ Hulk's electronic music mixes with tracklists - House, Tech House, Deep House, Latin House.",
  "url": "https://holger-kampffmeyer.de/dj/mixes-blog-archive/",
  "image": "https://holger-kampffmeyer.de/img/_81A4010.webp",
  "mainEntity": [blogSchema, {
    "@type": "MusicAlbum",
    "name": "DJ Hulk Mix Archive",
    "description": "All DJ mixes with tracklists by DJ Hulk",
    "byArtist": {
      "@type": "Person",
      "name": "DJ Hulk",
"url": "https://holger-kampffmeyer.de/djhulk-electronic-music/"
    },
    "genre": ["House", "Tech House", "Deep House", "Latin House"],
    "numTracks": archivePosts.length
  }]
};

const jsonLd: object[] = [collectionPageSchema, breadcrumbSchema, getDjPersonSchema()];
if (useCaseFilter) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "Thing",
    "name": USE_CASE_LABELS[useCaseFilter] || useCaseFilter,
    "description": `DJ mixes optimized for ${USE_CASE_LABELS[useCaseFilter] || useCaseFilter}`
  });
}
---

<Layout
  noSiteJsonLd
  title="Mix Archive - DJ Hulk Weekly DJ Mixes"
  description="Browse all DJ Hulk weekly mixes with tracklists. Filter by mood: gym, drive, work or pre-party. House, Tech House, Deep House, Latin House."
  image="/img/_81A4010.webp"
  jsonLd={jsonLd}
>
  <Navbar currentPage="/dj/mixes/" />

  <Breadcrumb segments={breadcrumbSegments} />

  <Hero
    image={heroImg}
  >
    <div class="max-w-3xl pt-32 text-center">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase animate-fadeInUp">All Mixcloud Mixes</span>
      <h1 class="font-play text-5xl md:text-7xl font-bold mb-6 gradient-text animate-fadeInUp stagger-2">All DJ Mixes</h1>
      <p class="text-[var(--color-text-muted)] text-xl mb-8 max-w-2xl animate-fadeInUp stagger-3">
        Browse all House & Tech House Mixes on Mixcloud
      </p>
      <a href="/dj/mixes-weekly" class="btn-primary animate-fadeInUp stagger-4">
        Weekly DJ Mixes →
      </a>
    </div>
  </Hero>
<style>
  .hero-slider {
    position: relative;
    aspect-ratio: 1287 / 859;
  }
  .slide-content {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-6xl mx-auto px-4">
      <script id="mixSearchData" type="application/json" set:html={JSON.stringify(searchablePosts)}></script>

      <div class="mix-search-wrapper mb-6">
        <svg class="mix-search-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input type="search" data-mix-search placeholder="Search by artist, title, or keyword..." aria-label="Search mixes" />
      </div>

      <div class="flex flex-wrap gap-3 mb-8" id="filterButtons">
        <a
          href="/dj/mixes-blog-archive"
          class="filter-btn min-w-[44px] min-h-[44px] px-4 py-2 rounded-lg border transition-colors bg-[var(--color-surface)] border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-primary)]"
        >
          All
        </a>
        <a
          href="/dj/mixes-blog-archive?useCase=gym"
          class="filter-btn min-w-[44px] min-h-[44px] px-4 py-2 rounded-lg border transition-colors flex items-center gap-2 bg-[var(--color-surface)] border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-primary)]"
        >
          <Icon name="gym" class="w-4 h-4" />
          <span>Gym</span>
        </a>
        <a
          href="/dj/mixes-blog-archive?useCase=drive"
          class="filter-btn min-w-[44px] min-h-[44px] px-4 py-2 rounded-lg border transition-colors flex items-center gap-2 bg-[var(--color-surface)] border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-primary)]"
        >
          <Icon name="drive" class="w-4 h-4" />
          <span>Drive</span>
        </a>
        <a
          href="/dj/mixes-blog-archive?useCase=work"
          class="filter-btn min-w-[44px] min-h-[44px] px-4 py-2 rounded-lg border transition-colors flex items-center gap-2 bg-[var(--color-surface)] border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-primary)]"
        >
          <Icon name="work" class="w-4 h-4" />
          <span>Work</span>
        </a>
        <a 
          href="/dj/mixes-blog-archive?useCase=party" 
          class="filter-btn min-w-[44px] min-h-[44px] px-4 py-2 rounded-lg border transition-colors flex items-center gap-2 bg-[var(--color-surface)] border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-primary)]"
        >
          <Icon name="party" class="w-4 h-4" />
          <span>Party</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="postsContainer">
        {archivePosts.map((post, index) => (
           <a 
             href={`/dj/mixes/${post.slug}`}
             class="post-item block bg-[var(--color-surface)] rounded-xl border border-[var(--color-border)] overflow-hidden hover:border-[var(--color-primary)] transition-colors group"
             data-usecases={JSON.stringify(post.useCases)}
             data-slug={post.slug}
             data-index={index}
           >
            <div class="aspect-video overflow-hidden">
              <img 
                src={post.picture} 
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-4">
              <div class="flex items-start justify-between gap-2 mb-2">
                <h2 class="font-play text-base font-bold text-[var(--color-text)] line-clamp-2 group-hover:text-[var(--color-primary)] transition-colors">
                  {post.title}
                </h2>
              </div>
              
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-3 text-xs">
                <div class="flex items-center gap-1">
                  <span class="text-[var(--color-text-muted)]">Date:</span>
                  <span class="text-[var(--color-primary)] font-medium bg-[var(--color-primary)]/10 px-2 py-0.5 rounded">
                    {post.created_time && formatDate(post.created_time)}
                  </span>
                </div>
                {post.audio_length && (
                  <div class="flex items-center gap-1">
                    <span class="text-[var(--color-text-muted)]">Mixlength:</span>
                    <span class="text-[var(--color-text)] font-medium bg-[var(--color-bg)] px-2 py-0.5 rounded border border-[var(--color-border)]">
                      {Math.floor(post.audio_length / 60)}:{String(post.audio_length % 60).padStart(2, '0')}
                    </span>
                  </div>
                )}
                {post.tracklist && post.tracklist.length > 0 && (
                  <div class="flex items-center gap-1">
                    <span class="text-[var(--color-text-muted)]">Tracks:</span>
                    <span class="text-[var(--color-text)] font-medium">
                      {post.tracklist.length}
                    </span>
                  </div>
                )}
              </div>
              
              <div class="flex flex-wrap gap-1.5">
                {post.useCases.map(useCase => {
                  const config = USECASE_CONFIG[useCase];
                  return (
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-[var(--color-bg)] rounded-full text-xs">
                        {config?.icon && <Icon name={config.icon} class={`w-3 h-3 ${config?.color || ''}`} />}
                        <span>{config?.label || useCase}</span>
                      </span>
                  );
                })}
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="flex justify-center items-center gap-4 mt-12">
        <button id="prevBtn" class="btn-primary disabled:opacity-50 disabled:cursor-not-allowed" disabled>
          ← Previous
        </button>
        <div id="pageNumbers" class="flex gap-2"></div>
        <button id="nextBtn" class="btn-primary">
          Next →
        </button>
      </div>

      <div class="text-center mt-8 mb-4">
        <p id="pageInfo" class="text-[var(--color-text-muted)]">Page 1 of {totalPages}</p>
      </div>

      <div class="text-center mt-12">
        <a href="/dj/mixes-weekly" class="btn-secondary">
          ← Back to Weekly DJ Mixes
        </a>
      </div>
    </div>
  </section>

  <Footer />

  <script src="/assets/mix-search.js" defer></script>
  <script is:inline src="/assets/archive-pagination.js" defer></script>
</Layout>
