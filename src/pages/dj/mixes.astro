---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import Footer from '../../components/Footer.astro';
import MixcloudWidget from '../../components/MixcloudWidget.astro';

interface MixcloudMix {
  title: string;
  key: string;
  url: string;
  created_time: string;
  src: string;
  description?: string | null;
  [key: string]: any;
}

interface MixcloudData {
  mixes: MixcloudMix[];
  lastUpdated?: string;
}

let mixcloudData: MixcloudData = { mixes: [] };

try {
  const imported = await import('../../data/mixcloud-data.json');
  if (imported && imported.default && Array.isArray(imported.default.mixes)) {
    mixcloudData = imported.default;
  }
} catch (e) {
  // eslint-disable-next-line no-console
  console.warn('Could not load mixcloud-data.json:', e);
  // mixcloudData remains { mixes: [] }
}

const allMixes = mixcloudData.mixes || [];

const mixesWithDetails = await Promise.all(
  allMixes.map(async (mix: MixcloudMix) => {
    try {
      const apiUrl = `https://api.mixcloud.com${mix.key}?metadata=1`;
      const response = await fetch(apiUrl);
      if (response.ok) {
        const data = await response.json();
        return {
          ...mix,
          description: data.description || null,
        };
      }
    } catch {
      // Silently ignore fetch errors
    }
    return { ...mix, description: null };
  })
);

const latestMix = mixesWithDetails[0];
const otherMixes = mixesWithDetails.slice(1);

const ITEMS_PER_PAGE = 6;
const totalPages = Math.ceil(otherMixes.length / ITEMS_PER_PAGE);
---

<Layout 
  title="DJ Mixes - DJ Hulk - Weekly Sunday House Mix"
  description="Wöchentliche House und Tech House Mixes von DJ Hulk auf Mixcloud. Spezialisiert auf Latin House, Jackin, Funky House und Afro House."
  image="/img/em3f/DSC_2451.webp"
>
  <Navbar currentPage="/dj/mixes" />

  <!-- Breadcrumb -->
  <div class="breadcrumb-section">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="breadcrumb">
        <a href="/">Startseite</a>
        <span class="separator">/</span>
        <a href="/djhulk-electronic-music">DJ Hulk</a>
        <span class="separator">/</span>
        <span class="current">Mixes</span>
      </nav>
    </div>
  </div>

  <Hero 
    image="/img/em3f/DSC_2451.webp"
    gradient="linear-gradient(135deg, rgba(10, 10, 15, 0.9) 0%, rgba(249, 115, 22, 0.2) 100%)"
  >
    <div class="max-w-3xl pt-32 text-center">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase animate-fadeInUp">Weekly House Music DJ Mixes</span>
      <h1 class="font-play text-5xl md:text-7xl font-bold mb-6 gradient-text animate-fadeInUp stagger-2">DJ Mixes</h1>
      <p class="text-[var(--color-text-muted)] text-xl mb-8 max-w-2xl animate-fadeInUp stagger-3">
        Jeden Sonntag neue House & Tech House Mixes auf Mixcloud
      </p>
    </div>
  </Hero>

  <!-- Latest Mix -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-8">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Neuester Mix</span>
        <h2 class="font-play text-4xl font-bold mt-4">{latestMix?.title || 'Weekly Sunday House Mix'}</h2>
      </div>
      <p class="text-[var(--color-text-muted)] mb-8 text-justify">
        Auf Mixcloud veröffentliche ich jeden Sonntag einen neuen Mix. Dabei spezialisiere ich mich auf House, Tech House, Latin House, Jackin and Funky House sowie Afro House. <br>
        Meine Mixe decken ein breits Spektrum elektronischer Musik ab und eignen sich zum Hören im Auto, im Fitnessstudio oder zu Hause. <br>
        Weitere Musikrichtungen wie Techno und Drum n Bass findest du ebenfalls in meinem Mixcloud‑Archiv.
      </p>
      
      {latestMix && (
        <MixcloudWidget 
          src={latestMix.src} 
          title={latestMix.title} 
          description={latestMix.description || undefined}
          url={latestMix.url}
          createdTime={latestMix.created_time}
          variant="featured"
        />
      )}
    </div>
  </section>

  <!-- All Mixes Grid with Pagination -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Archiv</span>
        <h2 class="font-play text-4xl font-bold mt-4">Alle DJ Mixes</h2>
        <p class="text-[var(--color-text-muted)] mt-2">Seite <span id="currentPageDisplay">1</span> von {totalPages}</p>
      </div>
      
      <div id="mixesGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-total-pages={totalPages} data-items-per-page={ITEMS_PER_PAGE}>
        {otherMixes.map((mix: MixcloudMix, index: number) => (
          <div class="mix-item" data-page={Math.floor(index / ITEMS_PER_PAGE) + 1} style={`display: ${Math.floor(index / ITEMS_PER_PAGE) + 1 === 1 ? 'block' : 'none'}`}>
            <MixcloudWidget 
              src={mix.src} 
              title={mix.title} 
              description={mix.description || undefined}
              url={mix.url}
              createdTime={mix.created_time}
              variant="card"
            />
          </div>
        ))}
      </div>

      <!-- Pagination -->
      <div class="flex justify-center items-center gap-4 mt-12">
        <button id="prevBtn" class="btn-primary disabled:opacity-50 disabled:cursor-not-allowed" disabled>
          ← Zurück
        </button>
        <div id="pageNumbers" class="flex gap-2">
          <!-- Page numbers generated by JS -->
        </div>
        <button id="nextBtn" class="btn-primary">
          Weiter →
        </button>
      </div>
    </div>

    <div class="text-center mt-12">
      <a href="https://www.mixcloud.com/holger-kampffmeyer/" target="_blank" class="btn-primary">
        Alle Mixes auf Mixcloud
      </a>
    </div>
  </section>

  <!-- Spotify Section -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto text-center">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Spotify</span>
      <h2 class="font-play text-4xl font-bold mt-4 mb-6">Meine Spotify Playlist</h2>
      <p class="text-[var(--color-text-muted)] mb-8">Wöchentlich aktualisierte Playlist mit den besten House Tunes!</p>
      
      <div class="rounded-xl overflow-hidden">
        <iframe style="border-radius:12px; width: 100%; height: 352px; border: none;" src="https://open.spotify.com/embed/playlist/2IiSXnINIWdFMewY55iJWA?utm_source=generator" allowfullscreen allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
      </div>
    </div>
  </section>

  <Footer />

   <script is:inline define:vars={{ ITEMS_PER_PAGE, totalPages }}>
    function initPagination() {
      const params = new URLSearchParams(window.location.search);
      let currentPage = parseInt(params.get('page')) || 1;
      currentPage = Math.max(1, Math.min(currentPage, totalPages));
      
      const grid = document.getElementById('mixesGrid');
      const items = grid.querySelectorAll('.mix-item');
      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');
      const pageDisplay = document.getElementById('currentPageDisplay');
      const pageNumbers = document.getElementById('pageNumbers');
      
      function showPage(page) {
        currentPage = page;
        
        items.forEach((item, index) => {
          const itemPage = Math.floor(index / ITEMS_PER_PAGE) + 1;
          if (itemPage === page) {
            item.style.display = 'block';
            const iframe = item.querySelector('iframe');
            if (iframe) {
              iframe.setAttribute('loading', 'lazy');
            }
          } else {
            item.style.display = 'none';
          }
        });
        
        pageDisplay.textContent = page;
        
        prevBtn.disabled = page === 1;
        nextBtn.disabled = page === totalPages;
        
        // Update URL
        const url = new URL(window.location);
        url.searchParams.set('page', page);
        window.history.replaceState({}, '', url);
        
        renderPageNumbers();
      }
      
      function renderPageNumbers() {
        pageNumbers.innerHTML = '';
        
        // Always show first page
        addPageButton(1, currentPage === 1);
        
        // Show ellipsis if needed
        if (currentPage > 3) {
          const ellipsis = document.createElement('span');
          ellipsis.className = 'px-2 text-[var(--color-text-muted)]';
          ellipsis.textContent = '...';
          pageNumbers.appendChild(ellipsis);
        }
        
        // Show pages around current
        for (let i = Math.max(2, currentPage - 1); i <= Math.min(totalPages - 1, currentPage + 1); i++) {
          addPageButton(i, i === currentPage);
        }
        
        // Show ellipsis if needed
        if (currentPage < totalPages - 2) {
          const ellipsis = document.createElement('span');
          ellipsis.className = 'px-2 text-[var(--color-text-muted)]';
          ellipsis.textContent = '...';
          pageNumbers.appendChild(ellipsis);
        }
        
        // Always show last page if more than 1
        if (totalPages > 1) {
          addPageButton(totalPages, currentPage === totalPages);
        }
      }
      
      function addPageButton(page, isActive) {
        const btn = document.createElement('button');
        btn.className = `w-10 h-10 rounded-lg font-semibold transition-colors ${
          isActive 
            ? 'bg-[var(--color-primary)] text-white' 
            : 'bg-[var(--color-surface)] text-[var(--color-text)] hover:bg-[var(--color-primary)] hover:text-white'
        }`;
        btn.textContent = page;
        btn.addEventListener('click', () => showPage(page));
        pageNumbers.appendChild(btn);
      }
      
      prevBtn.addEventListener('click', () => {
        if (currentPage > 1) showPage(currentPage - 1);
      });
      
      nextBtn.addEventListener('click', () => {
        if (currentPage < totalPages) showPage(currentPage + 1);
      });
      
      // Initial render
      showPage(currentPage);
    }
    
    // Run on page load
    initPagination();
  </script>

  <script is:inline src="https://widget.mixcloud.com/media/js/widgetApi.js"></script>
  
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var players = [];
      var iframes = document.querySelectorAll('iframe[src*="player-widget.mixcloud.com"]');
      
      iframes.forEach(function(iframe) {
        var player = Mixcloud.PlayerWidget(iframe);
        player.ready.then(function() {
          players.push(player);
          player.events.play.on(function() {
            players.forEach(function(p) {
              if (p !== player) {
                p.pause();
              }
            });
          });
        });
      });
    });
  </script>

  <style>
    .breadcrumb-section {
      padding-top: 120px;
      padding-bottom: 1rem;
      background: var(--color-bg);
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.875rem;
      color: var(--color-text-muted);
    }

    .breadcrumb a {
      color: var(--color-text-muted);
      transition: color 0.3s ease;
    }

    .breadcrumb a:hover {
      color: var(--color-secondary);
    }

    .breadcrumb .separator {
      color: var(--color-border);
    }

    .breadcrumb .current {
      color: var(--color-text);
    }
  </style>
</Layout>
