          Oder Kontakt aufnehmen!
        </a>
      </div>
    </div>
  </section>

  <!-- DJing Section -->
  <section id="djing" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <span
            class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
            >DJing</span
