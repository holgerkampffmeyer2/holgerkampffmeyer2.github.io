---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Holger Kampffmeyer [DJ Hulk] - Musikanlagen, Lichttechnik, Tontechnik"
  description="DJ Hulk - Holger Kampffmeyer. Verleih von Musikanlagen, Partyboxen, Lichttechnik und Tontechnik im Großraum Stuttgart. Electronic Music DJ für Events, Feiern und Hochzeiten."
  image="/img/header.jpg"
>
  <Navbar currentPage="/" />

  <!-- Hero Slider Section -->
  <section id="hero" class="hero-slider">
    <!-- Slide 1 -->
    <div class="slide slide-1 active" data-slide="0">
      <div class="slide-content">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl">
            <span
              class="text-[var(--color-secondary)] text-lg tracking-widest uppercase animate-fadeInUp stagger-1"
              >Electro, House, Tech House, DnB</span>
            <h1
              class="font-play text-5xl md:text-7xl lg:text-8xl font-bold mb-6 gradient-text animate-fadeInUp stagger-2"
            >
              DJ Hulk
            </h1>
            <p
              class="text-[var(--color-text-muted)] text-xl md:text-2xl mb-8 max-w-2xl animate-fadeInUp stagger-3"
            >
              DJ für elektronische Musik - House, Tech House, Drum n Base
            </p>
            <div
              class="flex flex-col sm:flex-row gap-4 animate-fadeInUp stagger-4"
            >
              <a href="#djing" class="btn-primary">Mehr über mich</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 2 -->
    <div class="slide slide-2" data-slide="1">
      <div class="slide-content">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl">
            <span
              class="text-[#22d3ee] text-lg tracking-widest uppercase animate-fadeInUp stagger-1"
              >Musikanlagen, PA, Partyanlagen</span>
            <h1
              class="font-play text-5xl md:text-7xl lg:text-8xl font-bold mb-6 gradient-text animate-fadeInUp stagger-2"
            >
              DJ Technik Verleih
            </h1>
            <p class="text-[var(--color-text-muted)] text-xl md:text-2xl mb-8 max-w-2xl animate-fadeInUp stagger-3">
              Partyboxen, DJ-Equipment, Licht, Nebel, Mikrofon - alles für Ihre
              Party!
            </p>
            <div
              class="flex flex-col sm:flex-row gap-4 animate-fadeInUp stagger-4"
            >
              <a href="/vermietung" class="btn-primary">Zur Vermietung</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 3 -->
    <div class="slide slide-3" data-slide="2">
      <div class="slide-content">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl">
            <span
              class="text-[var(--color-secondary)] text-lg tracking-widest uppercase animate-fadeInUp stagger-1"
              >Weekly House Music DJ Mixes</span>
            <h1
              class="font-play text-5xl md:text-7xl lg:text-8xl font-bold mb-6 gradient-text animate-fadeInUp stagger-2"
            >
              DJ Mixes
            </h1>
            <p
              class="text-[var(--color-text-muted)] text-xl md:text-2xl mb-8 max-w-2xl animate-fadeInUp stagger-3"
            >
              Jeden Sonntag neue House & Tech House Mixes auf Mixcloud
            </p>
            <div
              class="flex flex-col sm:flex-row gap-4 animate-fadeInUp stagger-4"
            >
              <a href="#mixes" class="btn-primary">Zu den Mixes</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 4 -->
    <div class="slide slide-4" data-slide="3">
      <div class="slide-content">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl">
            <span
              class="text-[#22d3ee] text-lg tracking-widest uppercase animate-fadeInUp stagger-1"
              >DevOps, Professional, Research</span>
            <h1
              class="font-play text-5xl md:text-7xl lg:text-8xl font-bold mb-6 gradient-text animate-fadeInUp stagger-2"
            >
              Work / Research
            </h1>
            <p
              class="text-[var(--color-text-muted)] text-xl md:text-2xl mb-8 max-w-2xl animate-fadeInUp stagger-3"
            >
              IT Professional, Cloud Native, Software Development
            </p>
            <div
              class="flex flex-col sm:flex-row gap-4 animate-fadeInUp stagger-4"
            >
              <a href="/work" class="btn-primary">Kontakt</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Slider Navigation -->
    <button class="slider-nav prev" id="slider-prev">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>
    <button class="slider-nav next" id="slider-next">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"></path>
      </svg>
    </button>

    <!-- Slider Dots -->
    <div class="slider-dots">
      <div class="slider-dot active" data-dot="0"></div>
      <div class="slider-dot" data-dot="1"></div>
      <div class="slider-dot" data-dot="2"></div>
      <div class="slider-dot" data-dot="3"></div>
    </div>

    <!-- Scroll Indicator -->
    <div
      class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-float z-20"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-8 w-8 text-[var(--color-text-muted)]"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>

  <!-- Vermietung Section -->
  <section id="vermietung" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 animate-on-scroll">
        <span
          class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
          >Vermietung</span>
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
          Musikanlagen, Partyboxen, Tontechnik und Licht
        </h2>
        <p class="text-[var(--color-text-muted)] max-w-3xl mx-auto">
          Vermietung / Verleih für Veranstaltungstechnik im Großraum Stuttgart,
          Leinfelden-Echterdingen, Tübingen, Esslingen und Umkreis. Wir bieten
          Partyboxen, Musikanlagen, DJ-Equipment, Lichttechnik und Beleuchtung
          für Ihre privaten Feiern, Firmen-Events, Vereinsfeiern, Messen und
          sonstige Veranstaltungen.
        </p>
      </div>

      <div class="text-center mt-12 animate-on-scroll">
        <p class="text-[var(--color-text-muted)] mb-6">
          Sie suchen nach einem DJ für elektronische Tanzmusik?
        </p>
        <a href="/vermietung" class="btn-primary">Zur Miettechnik!</a>
        <a
          href="#kontakt"
          class="btn-secondary flex items-center justify-center gap-2"
        >
          Oder Kontakt aufnehmen!
        </a>
      </div>
    </div>
  </section>

  <!-- Galerie Section -->
  <section id="galerie" class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 animate-on-scroll">
        <span
          class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
          >Galerie</span>
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4">Videos</h2>
      </div>

      <div class="video-grid">
        <div class="video-item group relative animate-on-scroll stagger-1">
          <a
            href="https://www.youtube.com/watch?v=HqM-zQy4sFc"
            target="_blank"
            class="block w-full h-full"
          >
            <img
              src="img/videos/djhulktomate.png"
              alt="DJ Hulk EM3F Aftermovie"
              class="w-full h-full object-cover"
            />
            <div
              class="absolute inset-0 bg-black/60 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
            >
              <div class="play-button">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-8 w-8 text-white ml-1"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M8 5v14l11-7z"></path>
                </svg>
              </div>
            </div>
            <div
              class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/80 to-transparent"
            >
              <h4 class="font-bold text-sm">
                DJ Hulk - EM3F Festival 2024 Aftermovie
              </h4>
            </div>
          </a>
        </div>

        <div class="video-item group relative animate-on-scroll stagger-2">
          <a
            href="https://www.youtube.com/watch?v=dvJtZv6AMd4"
            target="_blank"
            class="block w-full h-full"
          >
            <img
              src="img/videos/IMG_5641.jpg"
              alt="DJ Hulk Drum n Base"
              class="w-full h-full object-cover"
            />
            <div
              class="absolute inset-0 bg-black/60 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
            >
              <div class="play-button">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-8 w-8 text-white ml-1"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M8 5v14l11-7z"></path>
                </svg>
              </div>
            </div>
            <div
              class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/80 to-transparent"
            >
              <h4 class="font-bold text-sm">DJ Hulk - Drum n Base Session</h4>
            </div>
          </a>
        </div>

        <div class="video-item group relative animate-on-scroll stagger-3">
          <a
            href="https://www.youtube.com/watch?v=bXlv5JCuM-8"
            target="_blank"
            class="block w-full h-full"
          >
            <img
              src="img/videos/IMG_5639.jpg"
              alt="DJ Hulk Drum n Base 2"
              class="w-full h-full object-cover"
            />
            <div
              class="absolute inset-0 bg-black/60 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
            >
              <div class="play-button">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-8 w-8 text-white ml-1"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M8 5v14l11-7z"></path>
                </svg>
              </div>
            </div>
            <div
              class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/80 to-transparent"
            >
              <h4 class="font-bold text-sm">DJ Hulk - Drum n Base Session</h4>
            </div>
          </a>
        </div>

        <div class="video-item group relative animate-on-scroll stagger-4">
          <a
            href="https://www.youtube.com/watch?v=jI5PGVIE3fY"
            target="_blank"
            class="block w-full h-full"
          >
            <img
              src="img/videos/video1.png"
              alt="Outdoor Birthday Party"
              class="w-full h-full object-cover"
            />
            <div
              class="absolute inset-0 bg-black/60 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
            >
              <div class="play-button">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-8 w-8 text-white ml-1"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M8 5v14l11-7z"></path>
                </svg>
              </div>
            </div>
            <div
              class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/80 to-transparent"
            >
              <h4 class="font-bold text-sm">
                DJ Hulk at Outdoor Birthday Party
              </h4>
            </div>
          </a>
        </div>

        <div class="video-item group relative animate-on-scroll stagger-5">
          <a
            href="https://www.youtube.com/watch?v=4ahbk2bEzno"
            target="_blank"
            class="block w-full h-full"
          >
            <img
              src="img/videos/video2.png"
              alt="Outdoor Birthday Party 2"
              class="w-full h-full object-cover"
            />
            <div
              class="absolute inset-0 bg-black/60 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
            >
              <div class="play-button">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-8 w-8 text-white ml-1"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M8 5v14l11-7z"></path>
                </svg>
              </div>
            </div>
            <div
              class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/80 to-transparent"
            >
              <h4 class="font-bold text-sm">
                DJ Hulk at Outdoor Birthday Party
              </h4>
            </div>
          </a>
        </div>

        <div class="video-item group relative animate-on-scroll stagger-6">
          <a
            href="https://www.youtube.com/watch?v=gCHxs99R0Gg"
            target="_blank"
            class="block w-full h-full"
          >
            <img
              src="img/videos/video3.png"
              alt="Birthday Party"
              class="w-full h-full object-cover"
            />
            <div
              class="absolute inset-0 bg-black/60 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
            >
              <div class="play-button">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-8 w-8 text-white ml-1"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M8 5v14l11-7z"></path>
                </svg>
              </div>
            </div>
            <div
              class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/80 to-transparent"
            >
              <h4 class="font-bold text-sm">
                Birthday Party - LD Systems Maui 28 G3
              </h4>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- DJing Section -->
  <section id="djing" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <span
            class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
            >DJing</span>
          <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
            DJ Hulk - DJ für Elektronische Musik
          </h2>
          <p class="text-[var(--color-text-muted)] mb-4">
            Unter meinem Alter Ego DJ Hulk betätige ich mich als DJ für
            elektronische Musik. Auf Mixcloud veröffentliche ich wöchentliche
            DJ-Mixe (Weekly Sunday House Mix) mit den besten House und Tech
            House Tracks.
          </p>
          <p class="text-[var(--color-text-muted)] mb-4">
            Mein musikalisches Repertoire umfasst neben diversen House
            Stilrichtungen auch Drum n Base (DnB), R&B, 2000 Hip Hop, Reggae
            sowie Euro Dance der 90er - 2000er Jahre.
            <p>
              <a href="./mixes" class="primary-btn"
                >Weiter zu meinen wöchentlichen DJ Mixes...</a>
            </p>
          </p>
          <p class="text-[var(--color-text-muted)] mb-6">
            Als Mitgründer des DJ Kollektivs <strong
              class="text-[var(--color-primary)]"
              >ToMaTe Stuttgart n.e.V.</strong
            > organisiere ich Veranstaltungen für Elektronische Musik wie beispielsweise
            das jährlich stattfindende <strong
              class="text-[var(--color-primary)]"
              >Electronic Music Family and Friends Festival</strong
            >.
          </p>
          <p><a href="./em3f" class="primary-btn">Weitere Bilder...</a></p>
          <div class="text-center mt-12 animate-on-scroll">
            <a href="/em3f" class="btn-primary">Weitere Bilder...</a>
            <a
              href="/mixes"
              class="btn-secondary flex items-center justify-center gap-2"
              >Weitere DJ Mixes...</a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <img
            src="img/DSC_2311.jpg"
            alt="DJ Hulk"
            class="rounded-img object-cover aspect-square animate-on-scroll stagger-1"
          />
          <img
            src="img/_P8A4017.jpg"
            alt="DJ Hulk"
            class="rounded-img object-cover aspect-square animate-on-scroll stagger-2"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Mixes Section -->
  <section id="mixes" class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 animate-on-scroll">
        <span
          class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
          >Mixcloud</span>
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
          Meine DJ Mixes
        </h2>
        <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">
          Auf Mixcloud veröffentliche ich jeden Sonntag einen neuen Mix. Dabei
          spezialisiere ich mich auf Tech House, Latin House, Jackin and Funky
          House sowie Afro House.
        </p>
      </div>

      <div class="max-w-3xl mx-auto mb-12 animate-on-scroll">
        <div class="bg-[var(--color-bg)] rounded-xl p-4">
          <iframe
            width="100%"
            height="120"
            src="https://player-widget.mixcloud.com/widget/iframe/?hide_cover=1&feed=%2Fholger-kampffmeyer%2Fim-holding-you-afro-latin-tribal-house-mix123%2F"
            frameborder="0"></iframe>
        </div>
      </div>

      <div class="text-center animate-on-scroll">
        <span
          class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
          >Spotify</span>
        <h3 class="font-play text-2xl font-bold mt-4 mb-6">
          Meine Spotify Playlist
        </h3>
        <p class="text-[var(--color-text-muted)] mb-6">
          Wöchentlich aktualisierte Playlist mit den besten House Tunes!
        </p>
        <div class="max-w-3xl mx-auto">
          <iframe
            style="border-radius:12px"
            src="https://open.spotify.com/embed/playlist/2IiSXnINIWdFMewY55iJWA?utm_source=generator"
            width="100%"
            height="352"
            frameborder="0"
            allowfullscreen=""
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy"></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Kontakt Section -->
  <section id="kontakt" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto text-center animate-on-scroll">
      <span
        class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
        >Kontakt</span>
      <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
        Lass uns feiern!
      </h2>
      <p class="text-[var(--color-text-muted)] text-lg mb-10">
        Du planst eine Party oder Veranstaltung? Ich helfe dir gerne bei der
        Technik oder trete als DJ auf.
      </p>

      <div class="flex flex-col sm:flex-row gap-6 justify-center mb-12">
        <a
          href="mailto:holger.kampffmeyer+dj@gmail.com"
          class="btn-primary flex items-center justify-center gap-2"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
          holger.kampffmeyer+dj@gmail.com
        </a>
      </div>

      <!-- Social Links -->
      <div class="flex justify-center gap-6">
        <a
          href="https://www.facebook.com/holger.kampffmeyer"
          target="_blank"
          class="social-link"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-7 w-7"
            fill="currentColor"
            viewBox="0 0 24 24"
            ><path
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
            ></path></svg
          >
        </a>
        <a
          href="https://www.instagram.com/djhulk_de"
          target="_blank"
          class="social-link"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-7 w-7"
            fill="currentColor"
