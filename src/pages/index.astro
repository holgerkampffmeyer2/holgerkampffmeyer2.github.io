---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const faqs = [
  {
    question: "Wie viel kostet es, eine Partybox in Stuttgart zu mieten?",
    answer: "Unsere Partyboxen (z.B. JBL Partybox) sind bereits ab 80€ pro Boxenpaar und Tag verfügbar. Eine einzelne Box kostet 50€ pro Tag."
  },
  {
    question: "Welche PA-Anlage eignet sich für 50 Personen?",
    answer: "Für Veranstaltungen mit 50-80 Personen empfehle ich unsere JBL Partyboxen oder das LD Maui 28 G3 Komplettset. Beide sind Plug & Play und in 5 Minuten aufgebaut."
  },
  {
    question: "Wie funktioniert die Bezahlung?",
    answer: "Die Bezahlung erfolgt bei Abholung. Ich biete Barzahlung und PayPal an!"
  },
  {
    question: "Wo kann ich die Technik abholen?",
    answer: "Die Technik kann direkt in Leinfelden-Echterdingen (Magellanstraße 4) abgeholt werden. Ich erkläre dir ausführlich den Aufbau und gebe dir eine Einweisung."
  },
  {
    question: "Was kostet eine Party-Lichtanlage?",
    answer: "Eine vollständige Partylichtanlage mit verschiedenen Effekten ist bereits ab 50€ pro Tag verfügbar. Inklusive persönlicher Beratung und Einweisung."
  },
  {
    question: "Bietest du auch Pakete mit Nebelmaschine?",
    answer: "Ja, ich biete die Partylichtanlagen auch zusammen mit einer Nebelmaschine an. Das Komplettpaket gibt es ab 60€ pro Tag."
  },
  {
    question: "Brauche ich Vorkenntnisse, um die Anlage zu bedienen?",
    answer: "Nein, ich biete eine umfassende Einweisung an. Die Technik ist für jeden Benutzer einfach zu bedienen."
  }
];
---

<Layout
  title="Holger Kampffmeyer [DJ Hulk] - Musikanlagen, Lichttechnik, Tontechnik"
  description="DJ Hulk - Holger Kampffmeyer. Verleih von Musikanlagen, Partyboxen, Lichttechnik und Tontechnik im Großraum Stuttgart. Electronic Music DJ für Events, Feiern und Hochzeiten."
  image="/img/header.webp"
  jsonLd={
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    }
  }
>
  <Navbar currentPage="/" />

  <!-- Hero Slider Section -->
  <section id="hero" class="hero-slider">
    <!-- Slide 1: DJ Hulk -->
    <div class="slide slide-1 active" data-slide="0">
      <div class="slide-content">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl">
            <span
              class="text-[var(--color-secondary)] text-lg tracking-widest uppercase animate-fadeInUp stagger-1"
              >Electro, House, Tech House, Techno, DnB</span
            >
            <h1
              class="font-play text-5xl md:text-7xl lg:text-8xl font-bold mb-6 gradient-text animate-fadeInUp stagger-2"
            >
              DJ Hulk
            </h1>
            <p
              class="text-[var(--color-text-muted)] text-xl md:text-2xl mb-8 max-w-2xl animate-fadeInUp stagger-3"
            >
              Stuttgarter DJ für elektronische Musik - House, Tech House, Techno, Drum n Base
            </p>
            <div
              class="flex flex-col sm:flex-row gap-4 animate-fadeInUp stagger-4"
            >
              <a href="/djhulk-electronic-music" class="btn-primary">Mehr über DJ Hulk</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 2: DJ Technik Verleih -->
    <div class="slide slide-2" data-slide="1">
      <div class="slide-content">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl">
            <span
              class="text-[#22d3ee] text-lg tracking-widest uppercase animate-fadeInUp stagger-1"
              >Musikanlagen, PA, Partyanlagen</span
            >
            <h1
              class="font-play text-5xl md:text-7xl lg:text-8xl font-bold mb-6 gradient-text animate-fadeInUp stagger-2"
            >
              DJ Technik Verleih
            </h1>
            <p class="text-[var(--color-text-muted)] text-xl md:text-2xl mb-8 max-w-2xl animate-fadeInUp stagger-3">
              Partyboxen, DJ-Equipment, Licht, Nebel, Mikrofon - alles für Ihre
              Party!
            </p>
            <div
              class="flex flex-col sm:flex-row gap-4 animate-fadeInUp stagger-4"
            >
              <a href="/vermietung" class="btn-primary">Vermietung & Technik‑Verleih Stuttgart</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 3: Work/Research -->
    <div class="slide slide-3" data-slide="2">
      <div class="slide-content">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl">
            <span
              class="text-[#22d3ee] text-lg tracking-widest uppercase animate-fadeInUp stagger-1"
              >DevOps, Professional, Research</span
            >
            <h1
              class="font-play text-5xl md:text-7xl lg:text-8xl font-bold mb-6 gradient-text animate-fadeInUp stagger-2"
            >
              Work / Research
            </h1>
            <p
              class="text-[var(--color-text-muted)] text-xl md:text-2xl mb-8 max-w-2xl animate-fadeInUp stagger-3"
            >
              IT Professional, Cloud Native, Software Development
            </p>
            <div
              class="flex flex-col sm:flex-row gap-4 animate-fadeInUp stagger-4"
            >
              <a href="/work" class="btn-primary">Infos zu meinem Job und Research Papers</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Slider Navigation -->
    <button class="slider-nav prev" id="slider-prev">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>
    <button class="slider-nav next" id="slider-next">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"></path>
      </svg>
    </button>

    <!-- Slider Dots -->
    <div class="slider-dots">
      <div class="slider-dot active" data-dot="0"></div>
      <div class="slider-dot" data-dot="1"></div>
      <div class="slider-dot" data-dot="2"></div>
    </div>

    <!-- Scroll Indicator -->
    <div
      class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-float z-20"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-8 w-8 text-[var(--color-text-muted)]"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>

  <!-- Vermietung Section -->
  <section id="vermietung" class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 animate-on-scroll">
        <span
          class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
          >Vermietung</span
        >
        
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div class="grid grid-cols-2 gap-4">
          <img 
            src="/img/vermietung/IMG_7142.webp" 
            alt="Partytechnik Vermietung" 
            class="rounded-xl w-full aspect-square object-cover hover:ring-2 hover:ring-[var(--color-secondary)] hover:scale-[1.02] transition-all duration-300"
          />
          <img 
            src="/img/vermietung/jbl-set1.webp" 
            alt="JBL Partybox Set" 
            class="rounded-xl w-full aspect-square object-cover hover:ring-2 hover:ring-[var(--color-secondary)] hover:scale-[1.02] transition-all duration-300"
          />
        </div>
        <div class="animate-on-scroll">
          <h2 class="font-play text-4xl md:text-5xl font-bold mb-6">
          Musikanlagen, Partyboxen, Tontechnik und Licht
        </h2>
          <p class="text-[var(--color-text-muted)] mb-8">
            Vermietung / Verleih für Veranstaltungstechnik im Großraum Stuttgart,
            Leinfelden-Echterdingen, Tübingen, Esslingen und Umkreis. Wir bieten
            Partyboxen, Musikanlagen, DJ-Equipment, Lichttechnik und Beleuchtung
            für Ihre privaten Feiern, Firmen-Events, Vereinsfeiern, Messen und
            sonstige Veranstaltungen.
          </p>
        </div>
        </div>

      <!-- Was ich dir biete -->
      <div class="mt-16">
        <h3 class="font-play text-2xl md:text-3xl font-bold text-center mb-10">
          Was ich dir biete
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div class="bg-[var(--color-bg)] p-6 rounded-xl">
            <div class="w-12 h-12 bg-orange-500/20 rounded-lg flex items-center justify-center mb-4 text-orange-500">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
              </svg>
            </div>
            <h4 class="font-bold text-lg mb-2">PA-Anlagen & Partyboxen</h4>
            <p class="text-[var(--color-text-muted)] text-sm">
              Kraftvoller Sound für Partys, Hochzeiten und Vereinsfeiern. Professionelle Musikanlagen und Partyboxen.
            </p>
          </div>
          <div class="bg-[var(--color-bg)] p-6 rounded-xl">
            <div class="w-12 h-12 bg-orange-500/20 rounded-lg flex items-center justify-center mb-4 text-orange-500">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
              </svg>
            </div>
            <h4 class="font-bold text-lg mb-2">Lichttechnik</h4>
            <p class="text-[var(--color-text-muted)] text-sm">
              LED-Lichteffekte, Partylichtanlagen, Nebelmaschinen und komplette Lichtanlagen für die perfekte Stimmung.
            </p>
          </div>
          <div class="bg-[var(--color-bg)] p-6 rounded-xl">
            <div class="w-12 h-12 bg-orange-500/20 rounded-lg flex items-center justify-center mb-4 text-orange-500">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
              </svg>
            </div>
            <h4 class="font-bold text-lg mb-2">Komplettpakete</h4>
            <p class="text-[var(--color-text-muted)] text-sm">
              Vermietung von Kombi-Angeboten aus Sound & Licht. Zuverlässig, günstig und persönlich beraten.
            </p>
          </div>
          <div class="bg-[var(--color-bg)] p-6 rounded-xl">
            <div class="w-12 h-12 bg-orange-500/20 rounded-lg flex items-center justify-center mb-4 text-orange-500">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
              </svg>
            </div>
            <h4 class="font-bold text-lg mb-2">Warum bei mir mieten?</h4>
            <ul class="text-[var(--color-text-muted)] text-sm space-y-2">
              <li class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="check-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                Einfache Abholung in Stuttgart & Umgebung
              </li>
              <li class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="check-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                Persönliche Beratung & faire Preise
              </li>
              <li class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="check-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                Leistungsstarke Technik für kleine und große Events
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- FAQ -->
      <div class="mt-16">
        <h3 class="font-play text-2xl md:text-3xl font-bold text-center mb-10">
          Häufig gestellte Fragen
        </h3>
        <div class="max-w-3xl mx-auto space-y-4">
          {faqs.map((faq) => (
            <details class="bg-[var(--color-bg)] rounded-xl p-4 cursor-pointer group">
              <summary class="font-bold cursor-pointer flex items-center gap-3 list-none">
                <span class="w-6 h-6 bg-orange-500/20 rounded flex items-center justify-center text-orange-500 group-open:rotate-90 transition-transform">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                  </svg>
                </span>
                {faq.question}
              </summary>
              <p class="text-[var(--color-text-muted)] mt-3 ml-9">
                {faq.answer}
              </p>
            </details>
          ))}
        </div>
      </div>

      <div class="text-center mt-12 animate-on-scroll">
        <p class="text-[var(--color-text-muted)] mb-6">
          Sie suchen nach einem DJ für elektronische Tanzmusik?
        </p>
        <a href="/vermietung" class="btn-primary">Zur Miettechnik!</a>
        <a
          href="#kontakt"
          class="btn-secondary flex items-center justify-center gap-2"
        >
          Oder Kontakt aufnehmen!
        </a>
      </div>
    </div>
  </section>

  <!-- DJing Section -->
  <section id="djing" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <span
            class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
            >DJing</span
          >
          <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
            DJ Hulk - DJ für Elektronische Musik
          </h2>
          <p class="text-[var(--color-text-muted)] mb-4">
            Unter meinem Alter Ego <strong>DJ Hulk</strong> bin ich seit Jahren als DJ für elektronische Musik aktiv. 
            Ich lege bei privaten Partys, Firmenevents und kleineren Veranstaltungen auf - immer mit dem Fokus auf House, Techno und Drum n Bass.
          </p>
          
          <p class="text-[var(--color-text-muted)] mb-6">
            Auf <strong>Mixcloud</strong> veröffentliche ich wöchentliche DJ-Mixe und bin <strong>Resident DJ</strong> bei verschiedenen Online-Radiostationen.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/djhulk-electronic-music" class="btn-primary">Mehr über mich</a>
            <a href="/dj/mixes" class="btn-secondary">Zu den Mixes</a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <img
            src="/img/DSC_2311.webp"
            alt="DJ Hulk"
            class="rounded-xl w-full aspect-square object-cover hover:ring-2 hover:ring-[var(--color-secondary)] hover:scale-[1.02] transition-all duration-300 animate-on-scroll stagger-1"
          />
          <img
            src="/img/_81A4010.jpg"
            alt="DJ Hulk"
            class="rounded-xl w-full aspect-square object-cover hover:ring-2 hover:ring-[var(--color-secondary)] hover:scale-[1.02] transition-all duration-300 animate-on-scroll stagger-2"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Kontakt Section -->
  <section id="kontakt" class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-4xl mx-auto text-center animate-on-scroll">
      <span
        class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
        >Kontakt</span
      >
      <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
        Lass uns feiern!
      </h2>
      <p class="text-[var(--color-text-muted)] text-lg mb-10">
        Du planst eine Party oder Veranstaltung? Ich helfe dir gerne bei der
        Technik oder trete als DJ auf.
      </p>

      <div class="flex flex-col sm:flex-row gap-6 justify-center mb-12">
        <a
          href="mailto:holger.kampffmeyer+dj@gmail.com"
          class="btn-primary flex items-center justify-center gap-2"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
          holger.kampffmeyer+dj@gmail.com
        </a>
      </div>

      <!-- Social Links -->
      <div class="flex justify-center gap-6">
        <a
          href="https://www.facebook.com/holger.kampffmeyer"
          target="_blank"
          class="social-link"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-7 w-7"
            fill="currentColor"
            viewBox="0 0 24 24"
            ><path
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
            ></path></svg
          >
        </a>
        <a
          href="https://www.instagram.com/djhulk_de"
          target="_blank"
          class="social-link"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-7 w-7"
            fill="currentColor"
