const testimonials = [
  { name: 'Julian', role: 'Mieter Lichtanlage', text: 'Ich habe eine Lichtanlage für eine private Feier ausgeliehen und bin absolut begeistert! Super freundlicher Service, kompetente Beratung und sehr faire Preise.' },
  { name: 'Thomas', role: 'Mieter Musik- und Lichtanlage', text: 'Hatte bei Holger eine Sound- und Lichtanlage gemietet. Super netter Kontakt, gute Erklärung der Funktionen und alles reibungslos!' },
  { name: 'Dominik', role: 'Mieter Musikanlage', text: 'Top! Hat alles bestens geklappt! Ein zuverlässiger und seriöser Kontakt!' },
  { name: 'Wassim', role: 'Mieter Musikanlage', text: 'Ich habe eine Soundanlage gemietet und war sehr zufrieden. Holger war freundlich, zuverlässig und die Anlage hatte eine top Klangqualität.' },
  { name: 'Sesubasu', role: 'Mieter Lichtanlage', text: 'Tolles, leistungsfähiges und leicht zu bedienendes Equipment. Mietung und Kommunikation einfach und schnell!' },
  { name: 'Bernd', role: 'Mieter Lichtanlage und Nebelmaschine', text: 'Alle 5 Sterne in allem Gerechtfertigt!! Sehr Freundlich, Kompetent, Preis Leistung Top. Jederzeit wieder!' }
];
---

<Layout 
  title="Vermietung - DJ Hulk - Musikanlagen, Partyboxen, Lichttechnik"
  description="Verleih von Musikanlagen, Partyboxen, Lichttechnik, Nebelmaschinen und DJ-Equipment im Großraum Stuttgart. Faire Preise und professionelle Beratung."
  image="/img/vermietung/licht2.jpg"
>
  <Navbar currentPage="/vermietung" />

  <!-- Hero Section -->
  <section class="hero-slider">
    <div class="slide slide-1 active">
      <div class="slide-content" style="background-image: linear-gradient(135deg, rgba(10, 10, 15, 0.9) 0%, rgba(249, 115, 22, 0.2) 100%), url('/img/vermietung/licht2.jpg');">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl pt-32">
            <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase animate-fadeInUp">Musikanlagen, PA, Partyanlagen</span>
            <h1 class="font-play text-5xl md:text-7xl font-bold mb-6 gradient-text animate-fadeInUp stagger-2">Vermietung / Verleih</h1>
            <p class="text-[var(--color-text-muted)] text-xl mb-8 max-w-2xl animate-fadeInUp stagger-3">
              Partyboxen, DJ-Equipment, Licht, Nebel, Mikrofon - alles für Ihre Party!
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-play text-3xl md:text-4xl font-bold mb-6">Vermietung von Musikanlagen, PA Anlagen, Partyboxen und mehr!</h2>
      <p class="text-[var(--color-text-muted)] mb-6">
        Vermietung / Verleih von Veranstaltungstechnik im Großraum Stuttgart, Leinfelden-Echterdingen, Tübingen, Esslingen und Umkreis. Ich vermiete Partyboxen, Musikanlagen, DJ-Equipment, Lichttechnik und Beleuchtung für Ihre privaten Feiern, Firmen-Events, Vereinsfeiern, Messen und sonstige Veranstaltungen.
      </p>
      
      <div class="text-left bg-[var(--color-surface)] rounded-xl p-6 mt-8">
        <h3 class="font-bold text-xl mb-4">Ablauf der Mietanfrage:</h3>
        <ol class="space-y-3 text-[var(--color-text-muted)]">
          <li><span class="text-[var(--color-secondary)] font-bold">1.</span> Du nimmst Kontakt zu mir auf. Bitte teile mir den Mietzeitraum und die Art Deiner Veranstaltung mit.</li>
          <li><span class="text-[var(--color-secondary)] font-bold">2.</span> Sobald Deine Anfrage eingeht, melde ich mich umgehend bei Dir.</li>
          <li><span class="text-[var(--color-secondary)] font-bold">3.</span> Ich erstelle ein individuelles Angebot.</li>
          <li><span class="text-[var(--color-secondary)] font-bold">4.</span> Bei Gefallen bestätigst Du mir per Email das Angebot.</li>
          <li><span class="text-[var(--color-secondary)] font-bold">5.</span> Du holst die Technik ab. Bezahlung erfolgt bar oder per PayPal.</li>
          <li><span class="text-[var(--color-secondary)] font-bold">6.</span> Bei Rückgabe erhältst Du die Kaution zurück.</li>
        </ol>
      </div>
    </div>
  </section>

  <!-- Equipment Grid -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Vermietungskatalog</span>
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4">Unsere Technik</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {equipment.map((item, index) => (
          <div class="equipment-card" style={`animation-delay: ${index * 0.1}s`}>
            <img src={item.image} alt={item.title} class="rounded-img w-full h-64 object-cover mb-4" />
            <span class="text-[var(--color-secondary)] text-sm font-bold">{item.price}</span>
            <h3 class="text-xl font-bold mt-2 mb-3">{item.title}</h3>
            <p class="text-[var(--color-text-muted)] text-sm mb-4">{item.description}</p>
            <ul class="text-[var(--color-text-muted)] text-sm space-y-1">
              {item.features.map(feature => (
                <li class="flex items-center gap-2">
                  <span class="text-[var(--color-secondary)]">•</span> {feature}
                </li>
              ))}
            </ul>
            <a href="#kontakt" class="btn-primary w-full text-center mt-4 block">Jetzt anfragen</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section id="kontakt" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto text-center">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Kontakt</span>
      <h2 class="font-play text-4xl font-bold mt-4 mb-6">Technik anfragen</h2>
      <p class="text-[var(--color-text-muted)] mb-8">
        Frage gleich unverbindlich über das Formular Deine Wunschtechnik an. Oder schreibe mir eine Email an holger.kampffmeyer+dj@gmail.com
      </p>
      <div class="bg-[var(--color-surface)] rounded-xl p-4 h-[700px]">
        <iframe 
          src="https://docs.google.com/forms/d/e/1FAIpQLScdCjmRzpquqq0SkGiemkhvMDKPWWnsMvUVCHgkSphwJQ152A/viewform?embedded=true" 
          width="100%" 
          height="100%" 
          frameborder="0" 
          loading="lazy"
          title="Vermietungsformular"
        >
          Wird geladen…
        </iframe>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Rezensionen</span>
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4">Was sagen meine Kunden?</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map((testimonial, index) => (
          <div class="bg-[var(--color-bg)] rounded-xl p-6 border border-[var(--color-border)] hover:border-[var(--color-secondary)] hover:shadow-[0_0_30px_rgba(249,115,22,0.3)] transition-all duration-300" style={`animation-delay: ${index * 0.1}s`}>
            <img src="/img/5stars.png" alt="5 Sterne" class="h-6 mb-4" />
            <p class="text-[var(--color-text-muted)] mb-4">{testimonial.text}</p>
            <div class="border-t border-[var(--color-border)] pt-4">
              <h5 class="font-bold">{testimonial.name}</h5>
              <span class="text-sm text-[var(--color-text-muted)]">{testimonial.role}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
