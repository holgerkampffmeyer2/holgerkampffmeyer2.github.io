---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BieteSection from '../components/BieteSection.astro';

const targetUrl = 'https://soundundlicht-stuttgart.de/vermietung/';
---

<Layout
  title="Vermietung - Sound & Licht mieten in Stuttgart | DJ Hulk"
  description="Vermietung von PA-Anlagen, Partyboxen und Lichttechnik in Stuttgart. Alle Infos zu Preisen, Paketen und Verfügbarkeit auf soundundlicht-stuttgart.de."
>
  <Navbar currentPage="/vermietung/" />

  <section class="section-padding pt-32 bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto text-center">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Vermietung</span>
      <h1 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
        Vermietung umgezogen
      </h1>
      <p class="text-[var(--color-text-muted)] text-lg mb-4">
        Meine Vermietungsseite ist umgezogen zu <strong>soundundlicht-stuttgart.de</strong> – 
        dort findest du alle aktuellen Pakete, Preise und verfügbare Technik.
      </p>

      <a href={targetUrl} class="btn-primary text-xl px-8 py-4 mt-6 inline-block" target="_blank" rel="noopener">
        → Zur Vermietung auf soundundlicht-stuttgart.de
      </a>

      <BieteSection />
    </div>
  </section>

  <!-- FAQs -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-play text-3xl font-bold text-center mb-10">
        Vermietung — Häufige Fragen
      </h2>

      <div class="space-y-4">
        <details class="bg-[var(--color-bg)] rounded-xl p-6 cursor-pointer group">
          <summary class="font-bold text-lg flex items-center justify-between">
            Was kostet die Vermietung?
            <span class="text-[var(--color-secondary)] group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-4 text-[var(--color-text-muted)]">
            Die Preise richten sich nach Gerät und Mietdauer – von Partyboxen ab 50€/Tag bis zu Komplettpaketen. 
            Alle aktuellen Preise, Pakete und Verfügbarkeiten findest du auf meiner neuen Vermietungsseite.
          </p>
          <a href={targetUrl} class="btn-primary mt-4 inline-block" target="_blank" rel="noopener">
            Preise & Pakete ansehen →
          </a>
        </details>

        <details class="bg-[var(--color-bg)] rounded-xl p-6 cursor-pointer group">
          <summary class="font-bold text-lg flex items-center justify-between">
            Welche Technik kann ich mieten?
            <span class="text-[var(--color-secondary)] group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-4 text-[var(--color-text-muted)]">
            Von JBL Partyboxen und LD Maui Säulensystemen über LED-Lichtanlagen, Moving Heads, Laser Bars bis hin zu Komplettpaketen. 
            Eine detaillierte Übersicht mit Bildern und technischen Daten gibt es auf der neuen Seite.
          </p>
          <a href={targetUrl} class="btn-primary mt-4 inline-block" target="_blank" rel="noopener">
            Verfügbare Technik entdecken →
          </a>
        </details>

        <details class="bg-[var(--color-bg)] rounded-xl p-6 cursor-pointer group">
          <summary class="font-bold text-lg flex items-center justify-between">
            Wie läuft eine Vermietung ab?
            <span class="text-[var(--color-secondary)] group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-4 text-[var(--color-text-muted)]">
            Anfrage stellen, Verfügbarkeit prüfen, Abholung in Leinfelden-Echterdingen oder Lieferung vereinbaren – 
            mit ausführlicher Einweisung vor Ort. Alle Details zu Ablauf, Zahlung und Bedingungen findest du drüben.
          </p>
          <a href={targetUrl} class="btn-primary mt-4 inline-block" target="_blank" rel="noopener">
            Ablauf & Details erfahren →
          </a>
        </details>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
