---
import { Picture } from 'astro:assets';
import profileImg from '../assets/img/_81A4010.webp';
import Layout from '../layouts/Layout.astro';
import { getDjPersonSchema } from '../utils/dj-schema.js';
import FacebookIcon from "../components/icons/FacebookIcon.astro";
import InstagramIcon from "../components/icons/InstagramIcon.astro";
import YouTubeIcon from "../components/icons/YouTubeIcon.astro";
import MixcloudIcon from "../components/icons/MixcloudIcon.astro";
import SpotifyIcon from "../components/icons/SpotifyIcon.astro";
import LinkedInIcon from "../components/icons/LinkedInIcon.astro";
import XingIcon from "../components/icons/XingIcon.astro";
import ResidentAdvisorIcon from "../components/icons/ResidentAdvisorIcon.astro";
import RadioIcon from "../components/icons/RadioIcon.astro";
import EmailIcon from "../components/icons/EmailIcon.astro";
import SoundCloudIcon from "../components/icons/SoundCloudIcon.astro";
import GitHubIcon from "../components/icons/GitHubIcon.astro";
import DjHulkIcon from "../components/icons/DjHulkIcon.astro";
import VolumeUpIcon from "../components/icons/VolumeUpIcon.astro";

const links = [
  {
    name: "Sound & Licht Stuttgart",
    url: "https://soundundlicht-stuttgart.de/",
    icon: VolumeUpIcon,
    description: "Vermietung von PA-Anlagen, Partyboxen, Lichttechnik und DJ-Equipment in Stuttgart"
  },
  {
    name: "DJ Hulks Website",
    url: "https://holger-kampffmeyer.de/",
    icon: DjHulkIcon,
    description: "DJ Hulk - Electronic Music DJ aus Stuttgart"
  },
  {
    name: "Mixcloud",
    url: "https://www.mixcloud.com/holger-kampffmeyer/",
    icon: MixcloudIcon,
    description: "Weekly DJ Mixes - House, Tech House & mehr"
  },
  {
    name: "Instagram",
    url: "https://www.instagram.com/djhulk_de/",
    icon: InstagramIcon,
    description: "Neueste Updates & Stories"
  },
  {
    name: "Facebook",
    url: "https://www.facebook.com/djhulk.de",
    icon: FacebookIcon,
    description: "Events & News"
  },
  {
    name: "YouTube",
    url: "https://www.youtube.com/@djhulk_de",
    icon: YouTubeIcon,
    description: "Video-Mitschnitte & Aftermovies"
  },
  {
    name: "Spotify",
    url: "https://open.spotify.com/playlist/4u1RndvAi8kTQs85zhc8z4",
    icon: SpotifyIcon,
    description: "Aktuelle Playlist"
  },
  {
    name: "SoundCloud",
    url: "https://soundcloud.com/dj-hulk-337680700",
    icon: SoundCloudIcon,
    description: "Audiostreams & Uploads"
  },
  {
    name: "LinkedIn",
    url: "https://www.linkedin.com/in/holgerkampffmeyer/",
    icon: LinkedInIcon,
    description: "Berufliches Netzwerk"
  },
  {
    name: "Xing",
    url: "https://www.xing.com/profile/Holger_Kampffmeyer3/",
    icon: XingIcon,
    description: "Business-Profil"
  },
  {
    name: "GitHub",
    url: "https://github.com/holgerkampffmeyer2",
    icon: GitHubIcon,
    description: "Open Source - DJ Tools & DevOps"
  },
  {
    name: "Resident Advisor",
    url: "https://ra.co/dj/djhulk",
    icon: ResidentAdvisorIcon,
    description: "DJ Profil & Events"
  },
  {
    name: "Radio 365 FM",
    url: "https://www.365fmradio.de/",
    icon: RadioIcon,
    description: "DJ Hulk bei 365 FM Radio"
  },
  {
    name: "E-Mail",
    url: "mailto:holger.kampffmeyer@web.de",
    icon: EmailIcon,
    description: "Kontakt - Buchungen & Anfragen"
  }
];
---

<Layout
  title="DJ Hulk | Alle wichtigen Social-Media-Links & Kontakt"
  description="Alle wichtigen Links zu DJ Hulk: Instagram, Mixcloud, Spotify, YouTube, SoundCloud, Facebook und mehr. Folge DJ Hulk auf allen Plattformen."
  ogTitle="DJ Hulk — alle Social-Media-Links, Mixcloud & Kontakt"
  noSiteJsonLd
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://holger-kampffmeyer.de/"},
        {"@type": "ListItem", "position": 2, "name": "Links", "item": "https://holger-kampffmeyer.de/links/"}
      ]
    },
    getDjPersonSchema()
  ]}
>
  <section class="min-h-screen bg-[var(--color-bg)] py-12 md:py-16">
    <div class="max-w-sm mx-auto px-4">
      <div class="text-center mb-10">
        <Picture
          src={profileImg}
          formats={['avif', 'webp']}
          alt="DJ Hulk"
          class="w-28 h-28 rounded-full mx-auto mb-5 border-2 border-[var(--color-primary)] object-cover shadow-lg"
          loading="eager"
          fetchpriority="high"
          widths={[112]}
          sizes="112px"
        />
        <h1 class="font-play text-3xl font-bold gradient-text mb-1">
          DJ Hulk
        </h1>
        <p class="text-[var(--color-text-muted)] text-sm">
          Electronic Music DJ aus Stuttgart
        </p>
      </div>

      <div class="flex flex-col gap-3">
        {links.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 w-full bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl px-5 py-4 hover:border-[var(--color-primary)] hover:bg-[var(--color-surface-hover)] transition-all duration-200 hover:-translate-y-0.5 group"
          >
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center shrink-0"
              style="background-color: color-mix(in srgb, var(--color-secondary) 20%, transparent)"
            >
              <link.icon class="w-5 h-5" />
            </div>
            <div class="flex-1 min-w-0">
              <span class="font-semibold text-[var(--color-text)] group-hover:text-[var(--color-secondary)] transition-colors block">
                {link.name}
              </span>
              {link.description && (
                <span class="text-xs text-[var(--color-text-muted)] leading-snug block mt-0.5">
                  {link.description}
                </span>
              )}
            </div>
            <svg class="w-5 h-5 text-[var(--color-text-muted)] shrink-0 group-hover:text-[var(--color-primary)] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href="/"
          class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] transition-colors"
        >
          holger-kampffmeyer.de
        </a>
      </div>
    </div>
  </section>
</Layout>
