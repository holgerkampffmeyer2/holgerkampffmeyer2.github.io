      "priceRange": "€€",
      "telephone": "+49-171-1467491",
      "email": "holger.kampffmeyer+dj@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Magellanstraße 4",
        "addressLocality": "Leinfelden-Echterdingen",
        "postalCode": "70771",
        "addressRegion": "Baden-Württemberg",
        "addressCountry": "DE"
      },
      "areaServed": {
        "@type": "State",
        "name": "Baden-Württemberg"
      },
