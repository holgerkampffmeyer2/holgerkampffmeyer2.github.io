                  <Picture src={certImg} formats={['avif', 'webp']} alt="Ehrenurkunde 365 FM Radio" loading="lazy" class="rounded-lg hover:scale-[1.02] transition-transform max-w-xs sm:max-w-md mx-auto" widths={[400]} />
