    </div>
  </Hero>

  <SectionNav sections={[
    { id: "djing", label: "DJing" },
    { id: "galerie", label: "Videos" },
    { id: "mixes", label: "Mixes" },
    { id: "veranstaltungsarchiv", label: "Events" },
    { id: "radio", label: "Radio" },
    { id: "resident-advisor", label: "RA" },
    { id: "spotify", label: "Spotify" },
    { id: "kontakt", label: "Kontakt" },
  ]} />

  <!-- short summary for SEO and LLMs -->
  <section class="section-padding bg-[var(--color-surface)]" aria-labelledby="seo-summary-heading">
    <div class="max-w-3xl mx-auto text-center">
      <h2 id="seo-summary-heading" class="sr-only">Über DJ Hulk</h2>
