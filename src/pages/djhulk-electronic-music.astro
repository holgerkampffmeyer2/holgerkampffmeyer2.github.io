---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import { Picture } from 'astro:assets';
import Hero from "../components/Hero.astro";
import heroImg from "../assets/img/_81A4010.webp";
import djImg1 from "../assets/img/DSC_2311.webp";
import djImg2 from "../assets/img/_P8A4017.webp";
import certImg from "../assets/img/463B18D9-C20F-486C-8787-7543C1D9931F.webp";
import Footer from "../components/Footer.astro";
import RadioIcon from "../components/icons/RadioIcon.astro";
import EmailIcon from "../components/icons/EmailIcon.astro";
import FacebookIcon from "../components/icons/FacebookIcon.astro";
import InstagramIcon from "../components/icons/InstagramIcon.astro";
import MixcloudIcon from "../components/icons/MixcloudIcon.astro";
import SpotifyIcon from "../components/icons/SpotifyIcon.astro";
import YouTubeIcon from "../components/icons/YouTubeIcon.astro";
import ResidentAdvisorIcon from "../components/icons/ResidentAdvisorIcon.astro";
import MixcloudWidget from "../components/MixcloudWidget.astro";
import { getDjPersonSchema } from "../utils/dj-schema.js";
import { events } from "../data/events";
import SectionNav from "../components/SectionNav.astro";

interface BlogPostData {
   slug: string;
   title: string;
   key: string;
   url: string;
   created_time: string;
   src: string;
   description: string;
   picture: string;
   audio_length: number;
   tags: string[];
   useCases: string[];
   tracklist: string[];
   hasTracklist: boolean;
   heroImage?: string;
}

interface BlogData {
  posts: BlogPostData[];
}

let blogData: BlogData = { posts: [] };

try {
  const blogImported = await import("../data/blog-posts.json");
  if (blogImported && blogImported.default && Array.isArray(blogImported.default.posts)) {
    blogData = blogImported.default as unknown as BlogData;
  }
} catch (e) {
  console.warn('Could not load blog-posts.json:', e);
}

const searchablePosts = (blogData.posts || []).filter(post => post.hasTracklist).map(post => ({
  slug: post.slug,
  title: post.title,
  picture: post.picture,
  description: post.description?.substring(0, 300) || '',
  tags: post.tags,
  tracklist: post.tracklist || []
}));

interface MixcloudMix {
  title: string;
  key: string;
  url: string;
  created_time: string;
  src: string;
  description?: string | null;
  [key: string]: any;
}

interface MixcloudData {
  mixes: MixcloudMix[];
  lastUpdated?: string;
}

let mixcloudData: MixcloudData = { mixes: [] };

try {
  const imported = await import("../data/mixcloud-data.json");
  if (imported && imported.default && Array.isArray(imported.default.mixes)) {
    mixcloudData = imported.default;
  }
} catch (e) {
  console.warn('Could not load mixcloud-data.json:', e);
  // mixcloudData remains { mixes: [] }
}

const latestMix = mixcloudData.mixes && mixcloudData.mixes.length > 0 ? mixcloudData.mixes[0] : null;

const djPerson = getDjPersonSchema();
---

<Layout
  noSiteJsonLd
  title="DJ Hulk - Electronic Music DJ Stuttgart"
  description="DJ Hulk - Electronic Music DJ aus Stuttgart. House, Tech House, Drum n Bass. Weekly Sunday House Mixes auf Mixcloud. Events, Festivals und private Parties."
  image="/img/_81A4010.webp"
  preloadImage="/img/_81A4010.webp"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://holger-kampffmeyer.de/"},
        {"@type": "ListItem", "position": 2, "name": "DJ Hulk", "item": "https://holger-kampffmeyer.de/djhulk-electronic-music/"}
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "DJ Hulk - Electronic Music DJ Stuttgart",
      "description": "DJ Hulk - Electronic Music DJ aus Stuttgart. House, Tech House, Drum n Bass. Weekly Sunday House Mixes auf Mixcloud. Events, Festivals und private Parties.",
