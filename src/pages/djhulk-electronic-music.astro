                      <div class="text-[var(--color-text-muted)] text-[10px] leading-tight mt-1">{event.date} · {event.location}</div>
                      <p class="text-[var(--color-text-muted)] text-[10px] leading-tight mt-1 line-clamp-1">{event.description}</p>
                    </div>
