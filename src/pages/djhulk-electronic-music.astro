---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="DJ Hulk - Electronic Music DJ - House, Tech House, Drum n Bass"
  description="DJ Hulk - Electronic Music DJ aus Stuttgart. House, Tech House, Drum n Bass. Weekly Sunday House Mixes auf Mixcloud. Events, Festivals und private Parties."
  image="/img/header.webp"
>
  <Navbar currentPage="/djhulk-electronic-music" />

  <!-- Hero Section -->
  <section class="hero-slider">
    <div class="slide slide-1 active">
      <div class="slide-content">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl">
            <span
              class="text-[var(--color-secondary)] text-lg tracking-widest uppercase animate-fadeInUp"
              >Electro, House, Tech House, DnB</span
            >
            <h1
              class="font-play text-5xl md:text-7xl lg:text-8xl font-bold mb-6 gradient-text animate-fadeInUp stagger-2"
            >
              DJ Hulk
            </h1>
            <p
              class="text-[var(--color-text-muted)] text-xl md:text-2xl mb-8 max-w-2xl animate-fadeInUp stagger-3"
            >
              Stuttgarter DJ für elektronische Musik - House, Tech House, Drum n Base
            </p>
            <div
              class="flex flex-col sm:flex-row gap-4 animate-fadeInUp stagger-4"
            >
              <a href="#djing" class="btn-primary"
                >Infos zu DJ Hulk</a
              >
              <a href="#mixes" class="btn-secondary"
                >Meine DJ Mixes (Tech House)</a
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- short summary for SEO and LLMs -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-[var(--color-text-muted)]">
        DJ Hulk ist ein elektronischer DJ aus Stuttgart, spezialisiert auf
        House, Tech House, Techno und Drum n Bass. Hier findest du Informationen zu
        Auftritten, Mixes, Festival‑Projekte und Technik‑Verleih.
      </p>
    </div>
  </section>

  <!-- DJing Section -->
  <section id="djing" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <span
            class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
            >DJing</span
          >
          <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
            DJ Hulk - DJ für Elektronische Musik
          </h2>
          <p class="text-[var(--color-text-muted)] mb-4">
            Unter meinem Alter Ego DJ Hulk betätige ich mich als DJ für
            elektronische Musik. Auf Mixcloud veröffentliche ich wöchentliche
            DJ-Mixe (Weekly Sunday House Mix) mit den besten House und Tech
            House Tracks.
          </p>
          <p class="text-[var(--color-text-muted)] mb-4">
            Mein musikalisches Repertoire umfasst neben diversen House
            Stilrichtungen auch Drum n Base (DnB), R&B, 2000 Hip Hop, Reggae
            sowie Euro Dance der 90er - 2000er Jahre.
          </p>
          <p class="text-[var(--color-text-muted)] mb-6">
            Als Mitgründer des DJ Kollektivs <strong
              class="text-[var(--color-primary)]"
              >ToMaTe Stuttgart n.e.V.</strong
            > organisiere ich Veranstaltungen für Elektronische Musik wie beispielsweise
            das jährlich stattfindende <strong
              class="text-[var(--color-primary)]"
              >Electronic Music Family and Friends Festival</strong
            >.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/dj/mixes" class="btn-primary"
              >DJ Mixes (Stuttgart Tech House)</a
            >
            <a href="/dj/em3f" class="btn-secondary"
              >EM3F Electronic Music Festival</a
            >
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <img
            src="/img/DSC_2311.webp"
            alt="DJ Hulk"
            class="rounded-img object-cover aspect-square animate-on-scroll stagger-1"
          />
          <img
            src="/img/_P8A4017.webp"
            alt="DJ Hulk"
            class="rounded-img object-cover aspect-square animate-on-scroll stagger-2"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Videos Section -->
  <section id="galerie" class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 animate-on-scroll">
        <span
          class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
          >Videos</span
        >
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
          Meine Videos
        </h2>
        <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto mb-8">
          Event-Aufnahmen, Aftermovies und Party-Sessions auf meinem
          YouTube-Kanal.
        </p>
        <a href="/dj/videos" class="btn-primary"> Alle Videos ansehen </a>
      </div>
    </div>
  </section>

  <!-- Mixes Section -->
  <section id="mixes" class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 animate-on-scroll">
        <span
          class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
          >Mixcloud</span
        >
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
          Meine DJ Mixes
        </h2>
        <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">
          Auf Mixcloud veröffentliche ich jeden Sonntag einen neuen Mix. Dabei
          spezialisiere ich mich auf Tech House, Latin House, Jackin and Funky
          House sowie Afro House.
        </p>
      </div>

      <div class="max-w-3xl mx-auto mb-12 animate-on-scroll">
        <div class="bg-[var(--color-surface)] rounded-xl p-4">
          <iframe
            width="100%"
            height="120"
            src="https://player-widget.mixcloud.com/widget/iframe/?hide_cover=1&feed=%2Fholger-kampffmeyer%2Fdj-hulk-deep-tech-minimal-house-mix161%2F"
            style="border: none;"
            allow="encrypted-media; fullscreen; autoplay; idle-detection; speaker-selection; web-share;"
          ></iframe>
        </div>
      </div>

      <div class="text-center animate-on-scroll">
        <a href="/dj/mixes" class="btn-primary">Alle Mixes ansehen</a>
      </div>
    </div>
  </section>

      <!-- Veranstaltungsarchiv Section -->
      <section id="veranstaltungsarchiv" class="section-padding bg-[var(--color-surface)]">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12 animate-on-scroll">
            <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Veranstaltungsarchiv</span>
            <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">Ausgewählte Veranstaltungen & Flyer</h2>
            <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">Eine Auswahl vergangener Gigs, Festivals und Clubnächte. Klick auf eine Karte für Details.</p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 animate-on-scroll">
            <!-- Card 1 -->
            <article class="bg-[var(--color-bg)] rounded-xl overflow-hidden shadow-sm hover:scale-[1.01] transition-transform">
              <a href="/img/events/adp-afterhour-clubbing.jpg" target="_blank" class="block">
                <picture>
                  <source srcset="/img/events/adp-afterhour-clubbing.webp" type="image/webp" />
                  <img src="/img/events/adp-afterhour-clubbing.jpg" alt="ADP Afterhour Clubbing" class="w-full object-cover aspect-[4/3]" />
                </picture>
                <div class="p-4">
                  <h3 class="font-play text-xl font-bold mb-1">ADP Afterhour Clubbing</h3>
                  <div class="text-[var(--color-text-muted)] text-sm mb-2">Datum: 05.08.2023 · Ort: Club XY, Stuttgart</div>
                  <p class="text-[var(--color-text-muted)] text-sm">House & Tech House Afterhour mit Special Guest Sets.</p>
                </div>
              </a>
            </article>

            <!-- Card 2 -->
            <article class="bg-[var(--color-bg)] rounded-xl overflow-hidden shadow-sm hover:scale-[1.01] transition-transform">
              <a href="/img/events/Entdeckerfest-nowhatsapp-2025.png" target="_blank" class="block">
                <picture>
                  <source srcset="/img/events/Entdeckerfest-nowhatsapp-2025.webp" type="image/webp" />
                  <img src="/img/events/Entdeckerfest-nowhatsapp-2025.png" alt="Entdeckerfest 2025" class="w-full object-cover aspect-[4/3]" />
                </picture>
                <div class="p-4">
                  <h3 class="font-play text-xl font-bold mb-1">Entdeckerfest</h3>
                  <div class="text-[var(--color-text-muted)] text-sm mb-2">Datum: 12.07.2025 · Ort: Innenstadtfestival</div>
                  <p class="text-[var(--color-text-muted)] text-sm">Open-Air Festival mit elektronischer Bühne und Afterparty.</p>
                </div>
              </a>
            </article>

            <!-- Card 3 -->
            <article class="bg-[var(--color-bg)] rounded-xl overflow-hidden shadow-sm hover:scale-[1.01] transition-transform">
              <a href="/img/events/EM3F%202024.jpg" target="_blank" class="block">
                <picture>
                  <source srcset="/img/events/EM3F%202024.webp" type="image/webp" />
                  <img src="/img/events/EM3F%202024.jpg" alt="EM3F 2024" class="w-full object-cover aspect-[4/3]" />
                </picture>
                <div class="p-4">
                  <h3 class="font-play text-xl font-bold mb-1">Electronic Music Family & Friends 2024</h3>
                  <div class="text-[var(--color-text-muted)] text-sm mb-2">Datum: 21.09.2024 · Ort: Festivalgelände, Stuttgart</div>
                  <p class="text-[var(--color-text-muted)] text-sm">Festival-Projekt mit lokalen und internationalen Acts.</p>
                </div>
              </a>
            </article>

            <!-- Card 4 -->
            <article class="bg-[var(--color-bg)] rounded-xl overflow-hidden shadow-sm hover:scale-[1.01] transition-transform">
              <a href="/img/events/Poster%20-%2020%20Jahre%20Propp%20v2.png" target="_blank" class="block">
                <picture>
                  <source srcset="/img/events/Poster%20-%2020%20Jahre%20Propp%20v2.webp" type="image/webp" />
                  <img src="/img/events/Poster%20-%2020%20Jahre%20Propp%20v2.png" alt="20 Jahre Propp" class="w-full object-cover aspect-[4/3]" />
                </picture>
                <div class="p-4">
                  <h3 class="font-play text-xl font-bold mb-1">20 Jahre Propp</h3>
                  <div class="text-[var(--color-text-muted)] text-sm mb-2">Datum: 14.10.2022 · Ort: Propp Club</div>
                  <p class="text-[var(--color-text-muted)] text-sm">Jubiläumsparty mit alten Weggefährten und special DJ line-up.</p>
                </div>
              </a>
            </article>

            <!-- Card 5 -->
            <article class="bg-[var(--color-bg)] rounded-xl overflow-hidden shadow-sm hover:scale-[1.01] transition-transform">
              <a href="/img/events/boho-vibes-juni-23.jpg" target="_blank" class="block">
                <picture>
                  <source srcset="/img/events/boho-vibes-juni-23.webp" type="image/webp" />
                  <img src="/img/events/boho-vibes-juni-23.jpg" alt="Boho Vibes Juni 23" class="w-full object-cover aspect-[4/3]" />
                </picture>
                <div class="p-4">
                  <h3 class="font-play text-xl font-bold mb-1">Boho Vibes</h3>
                  <div class="text-[var(--color-text-muted)] text-sm mb-2">Datum: 10.06.2023 · Ort: Beachclub</div>
                  <p class="text-[var(--color-text-muted)] text-sm">Sommerliche Chill & Dance Sessions am Wasser.</p>
                </div>
              </a>
            </article>

            <!-- Card 6 -->
            <article class="bg-[var(--color-bg)] rounded-xl overflow-hidden shadow-sm hover:scale-[1.01] transition-transform">
              <a href="/img/events/romys-clubnight-7563-40E0-A4C1-BC2ED29D5257.jpg" target="_blank" class="block">
                <picture>
                  <source srcset="/img/events/romys-clubnight-7563-40E0-A4C1-BC2ED29D5257.webp" type="image/webp" />
                  <img src="/img/events/romys-clubnight-7563-40E0-A4C1-BC2ED29D5257.jpg" alt="Romy's Clubnight" class="w-full object-cover aspect-[4/3]" />
                </picture>
                <div class="p-4">
                  <h3 class="font-play text-xl font-bold mb-1">Romy's Clubnight</h3>
                  <div class="text-[var(--color-text-muted)] text-sm mb-2">Datum: 02.11.2023 · Ort: Romy's Club</div>
                  <p class="text-[var(--color-text-muted)] text-sm">Clubnight mit elektronischer Bassline und Live Acts.</p>
                </div>
              </a>
            </article>
          </div>
        </div>
      </section>

   <!-- Radio Stations Section -->
  <section id="radio" class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 animate-on-scroll">
        <span
          class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
          >Radio</span
        >
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
          Resident DJ bei Web-Radios
        </h2>
        <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">
          Als Resident DJ bin ich regelmäßig bei verschiedenen Online-Radiostationen zu hören. 
          24/7 Electronic Music Streams mit Live-DJ-Sessions am Wochenende.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- 365 FM Radio -->
        <a 
          href="https://www.365fmradio.de/" 
          target="_blank"
          class="bg-[var(--color-bg)] rounded-xl p-6 hover:scale-[1.02] transition-transform group"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-[var(--color-primary)] rounded-lg flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
              </svg>
            </div>
            <div>
              <h3 class="font-play text-xl font-bold group-hover:text-[var(--color-secondary)] transition-colors">
                365 FM Radio
              </h3>
              <span class="text-[var(--color-text-muted)] text-sm">Electronic Music 24/7</span>
            </div>
          </div>
          <p class="text-[var(--color-text-muted)] text-sm">
            365 FM Radio - elektronische Musik 24/7. Die heißesten Beats und die besten DJs direkt aus der Szene.
          </p>
        </a>

        <!-- CouchRadio -->
        <a 
          href="https://www.couchradio.ch/" 
          target="_blank"
          class="bg-[var(--color-bg)] rounded-xl p-6 hover:scale-[1.02] transition-transform group"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-[var(--color-primary)] rounded-lg flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
              </svg>
            </div>
            <div>
              <h3 class="font-play text-xl font-bold group-hover:text-[var(--color-secondary)] transition-colors">
                CouchRadio
              </h3>
              <span class="text-[var(--color-text-muted)] text-sm">Finest Deep House & Tech House</span>
            </div>
          </div>
          <p class="text-[var(--color-text-muted)] text-sm">
            CouchRadio - Welcome to the Stream! Finest Deep House, Progressive, Vocal, Tech House and more 24/7.
          </p>
        </a>
      </div>
    </div>
  </section>

    <!-- Resident Advisor Section -->
    <section class="section-padding bg-[var(--color-bg)]">
      <div class="max-w-7xl mx-auto">
        <div class="text-center animate-on-scroll">
          <span
            class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
            >Resident Advisor</span
          >
          <h3 class="font-play text-2xl font-bold mt-4 mb-6">
            Mein Resident Advisor Profil
          </h3>
          <p class="text-[var(--color-text-muted)] mb-6">
            Hier findest du alle meine Gigs, eine kurze Biografie und einige
            Mixes.
            <a
              href="https://de.ra.co/dj/djhulk"
              target="_blank"
              class="text-[var(--color-primary)] underline"
              >Besuche mein Resident Advisor Profil</a
            >
          </p>
        </div>
      </div>
    </section>

    <!-- Spotify Section -->
    <section class="section-padding bg-[var(--color-surface)]">
      <div class="max-w-7xl mx-auto">
        <div class="text-center animate-on-scroll">
          <span
            class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
            >Spotify</span
          >
          <h3 class="font-play text-2xl font-bold mt-4 mb-6">
            Meine Spotify Playlist
          </h3>
          <p class="text-[var(--color-text-muted)] mb-6">
            Wöchentlich aktualisierte Playlist mit den besten House Tunes!
          </p>
          <div class="max-w-3xl mx-auto">
            <iframe
              style="border-radius:12px"
              src="https://open.spotify.com/embed/playlist/2IiSXnINIWdFMewY55iJWA?utm_source=generator"
              width="100%"
              height="352"
              style="border: none;"
              allowfullscreen=""
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              loading="lazy"></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- Kontakt Section -->
    <section id="kontakt" class="section-padding bg-[var(--color-bg)]">
      <div class="max-w-4xl mx-auto text-center animate-on-scroll">
        <span
          class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
          >Kontakt</span
        >
        <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
          Buch mich für dein Event!
        </h2>
        <p class="text-[var(--color-text-muted)] text-lg mb-10">
          Du planst eine Party oder Veranstaltung? Ich trete gerne als DJ bei
          dir auf.
        </p>

        <div class="flex flex-col sm:flex-row gap-6 justify-center mb-12">
          <a
            href="mailto:holger.kampffmeyer+dj@gmail.com"
            class="btn-primary flex items-center justify-center gap-2"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            holger.kampffmeyer+dj@gmail.com
          </a>
        </div>

        <!-- Social Links -->
        <div class="flex justify-center gap-6">
          <a
            href="https://www.facebook.com/holger.kampffmeyer"
            target="_blank"
            class="social-link"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-7 w-7"
              fill="currentColor"
              viewBox="0 0 24 24"
              ><path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path></svg
            >
          </a>
          <a
            href="https://www.instagram.com/djhulk_de"
            target="_blank"
            class="social-link"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-7 w-7"
              fill="currentColor"
              viewBox="0 0 24 24"
              ><path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
              ></path></svg
            >
          </a>
          <a
            href="https://www.mixcloud.com/holger-kampffmeyer/"
            target="_blank"
            class="social-link"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-7 w-7"
              fill="currentColor"
