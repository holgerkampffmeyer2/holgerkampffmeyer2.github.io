      <div class="text-center animate-on-scroll">
        <a href="/dj/mixes" class="btn-primary">Alle Mixes ansehen</a>
      </div>
    </div>
  </section>

      <!-- Veranstaltungsarchiv Section -->
      <section id="veranstaltungsarchiv" class="section-padding bg-[var(--color-surface)]">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12 animate-on-scroll">
            <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Veranstaltungsarchiv</span>
