          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 animate-on-scroll">
            <!-- Card 1: 20 Jahre Propp (14.10.2022) -->
            <article class="bg-[var(--color-bg)] rounded-xl overflow-hidden shadow-sm border border-[var(--color-border)] hover:border-[var(--color-secondary)] hover:shadow-[0_0_30px_rgba(249,115,22,0.3)] transition-all duration-300 hover:scale-[1.01]">
              <a href="/img/events/Poster%20-%2020%20Jahre%20Propp%20v2.png" target="_blank" class="block">
                <div class="bg-black flex items-center justify-center" style="aspect-ratio: 3/4;">
                  <picture>
                    <source srcset="/img/events/Poster%20-%2020%20Jahre%20Propp%20v2.webp" type="image/webp" />
                    <img src="/img/events/Poster%20-%2020%20Jahre%20Propp%20v2.png" alt="20 Jahre Propp" class="h-full object-contain" />
                  </picture>
                </div>
                <div class="p-4">
                  <h3 class="font-play text-xl font-bold mb-1">20 Jahre Propp Fiseure</h3>
                  <div class="text-[var(--color-text-muted)] text-sm mb-2">Datum: 14.10.2022 · Ort: Propp Friseursalon</div>
                  <p class="text-[var(--color-text-muted)] text-sm">Jubiläumsparty und Firmenfest mit DJ Hulk.</p>
                </div>
              </a>
            </article>

            <!-- Card 2: Boho Vibes (10.06.2023) -->
            <article class="bg-[var(--color-bg)] rounded-xl overflow-hidden shadow-sm border border-[var(--color-border)] hover:border-[var(--color-secondary)] hover:shadow-[0_0_30px_rgba(249,115,22,0.3)] transition-all duration-300 hover:scale-[1.01]">
              <a href="/img/events/boho-vibes-juni-23.webp" target="_blank" class="block">
                <div class="bg-black flex items-center justify-center aspect-[4/3]">
                  <picture>
                    <source srcset="/img/events/boho-vibes-juni-23.webp" type="image/webp" />
                    <img src="/img/events/boho-vibes-juni-23.webp" alt="Boho Vibes Juni 23" class="w-full h-full object-contain" />
                  </picture>
                </div>
                <div class="p-4">
                  <h3 class="font-play text-xl font-bold mb-1">Boho Vibes</h3>
                  <div class="text-[var(--color-text-muted)] text-sm mb-2">Datum: 10.06.2023 · Ort: Mauritius Stuttgart Süd</div>
                  <p class="text-[var(--color-text-muted)] text-sm">Sommerparty, bei der ich als DJ mitgewirkt habe.</p>
                </div>
              </a>
            </article>

            <!-- Card 3: ADP Afterhour Clubbing (05.08.2023) -->
            <article class="bg-[var(--color-bg)] rounded-xl overflow-hidden shadow-sm border border-[var(--color-border)] hover:border-[var(--color-secondary)] hover:shadow-[0_0_30px_rgba(249,115,22,0.3)] transition-all duration-300 hover:scale-[1.01]">
              <a href="/img/events/adp-afterhour-clubbing.webp" target="_blank" class="block">
                <div class="bg-black flex items-center justify-center aspect-[4/3]">
                  <picture>
                    <source srcset="/img/events/adp-afterhour-clubbing.webp" type="image/webp" />
                    <img src="/img/events/adp-afterhour-clubbing.webp" alt="ADP Afterhour Clubbing" class="w-full h-full object-contain" />
                  </picture>
                </div>
                <div class="p-4">
                  <h3 class="font-play text-xl font-bold mb-1">ADP Afterhour Clubbing</h3>
                  <div class="text-[var(--color-text-muted)] text-sm mb-2">Datum: 05.08.2023 · Ort: Vector, Stuttgart</div>
                  <p class="text-[var(--color-text-muted)] text-sm">Afterhour / Firmenfeier, bei der ich als DJ für die musikalische Gestaltung verantwortlich war.</p>
                </div>
              </a>
            </article>

            <!-- Card 4: ADP Evening Event (12.08.2023) -->
            <article class="bg-[var(--color-bg)] rounded-xl overflow-hidden shadow-sm border border-[var(--color-border)] hover:border-[var(--color-secondary)] hover:shadow-[0_0_30px_rgba(249,115,22,0.3)] transition-all duration-300 hover:scale-[1.01]">
              <a href="/img/events/adp-evening-event-D724-4447-B663-073246B13C8B.webp" target="_blank" class="block">
                <div class="bg-black flex items-center justify-center aspect-[4/3]">
                  <picture>
                    <source srcset="/img/events/adp-evening-event-D724-4447-B663-073246B13C8B.webp" type="image/webp" />
                    <img src="/img/events/adp-evening-event-D724-4447-B663-073246B13C8B.webp" alt="ADP Evening Event" class="w-full h-full object-contain" />
                  </picture>
                </div>
                <div class="p-4">
                  <h3 class="font-play text-xl font-bold mb-1">ADP Evening Event 2023</h3>
                  <div class="text-[var(--color-text-muted)] text-sm mb-2">Datum: 12.08.2023 · Ort: Vector Stuttgart</div>
                  <p class="text-[var(--color-text-muted)] text-sm">DJ Auftritt bei einer Firmenveranstaltung.</p>
                </div>
              </a>
            </article>

            <!-- Card 5: Romy's Clubnight (02.11.2023) -->
            <article class="bg-[var(--color-bg)] rounded-xl overflow-hidden shadow-sm border border-[var(--color-border)] hover:border-[var(--color-secondary)] hover:shadow-[0_0_30px_rgba(249,115,22,0.3)] transition-all duration-300 hover:scale-[1.01]">
              <a href="/img/events/romys-clubnight-7563-40E0-A4C1-BC2ED29D5257.webp" target="_blank" class="block">
                <div class="bg-black flex items-center justify-center aspect-[4/3]">
                  <picture>
                    <source srcset="/img/events/romys-clubnight-7563-40E0-A4C1-BC2ED29D5257.webp" type="image/webp" />
                    <img src="/img/events/romys-clubnight-7563-40E0-A4C1-BC2ED29D5257.webp" alt="Romy's Clubnight" class="w-full h-full object-contain" />
                  </picture>
                </div>
                <div class="p-4">
                  <h3 class="font-play text-xl font-bold mb-1">Romy's Clubnight 2023</h3>
                  <div class="text-[var(--color-text-muted)] text-sm mb-2">Datum: 02.11.2023 · Ort: Romy's Club, Stuttgart</div>
                  <p class="text-[var(--color-text-muted)] text-sm">Clubnight mit elektronischer Musik bei der ich als DJ und Mit-Organisator mitgewirkt habe.</p>
                </div>
              </a>
            </article>

            <!-- Card 6: EM3F Festival 2024 (21.09.2024) -->
            <article class="bg-[var(--color-bg)] rounded-xl overflow-hidden shadow-sm border border-[var(--color-border)] hover:border-[var(--color-secondary)] hover:shadow-[0_0_30px_rgba(249,115,22,0.3)] transition-all duration-300 hover:scale-[1.01]">
              <a href="/img/events/EM3F%202024.webp" target="_blank" class="block">
                <div class="bg-black flex items-center justify-center aspect-[4/3]">
                  <picture>
                    <source srcset="/img/events/EM3F%202024.webp" type="image/webp" />
                    <img src="/img/events/EM3F%202024.webp" alt="EM3F 2024" class="w-full h-full object-contain" />
                  </picture>
                </div>
                <div class="p-4">
                  <h3 class="font-play text-xl font-bold mb-1">Electronic Music Family & Friends 2024</h3>
                  <div class="text-[var(--color-text-muted)] text-sm mb-2">Datum: 21.09.2024 · Ort: Kulturinsel Stuttgart</div>
                  <p class="text-[var(--color-text-muted)] text-sm">Festival-Projekt mit lokalen und internationalen DJ Acts, bei der ich als DJ aufgetreten bin sowie als Mit-Organisator mitgewirkt habe.</p>
                </div>
              </a>
            </article>

            <!-- Card 7: Entdeckerfest 2025 (12.07.2025) -->
            <article class="bg-[var(--color-bg)] rounded-xl overflow-hidden shadow-sm border border-[var(--color-border)] hover:border-[var(--color-secondary)] hover:shadow-[0_0_30px_rgba(249,115,22,0.3)] transition-all duration-300 hover:scale-[1.01]">
              <a href="/img/events/Entdeckerfest-nowhatsapp-2025.png" target="_blank" class="block">
                <div class="bg-black flex items-center justify-center" style="aspect-ratio: 9/16;">
                  <picture>
                    <source srcset="/img/events/Entdeckerfest-nowhatsapp-2025.webp" type="image/webp" />
                    <img src="/img/events/Entdeckerfest-nowhatsapp-2025.png" alt="Entdeckerfest 2025" class="h-full object-contain" />
                  </picture>
                </div>
                <div class="p-4">
                  <h3 class="font-play text-xl font-bold mb-1">Entdeckerfest 2025</h3>
                  <div class="text-[var(--color-text-muted)] text-sm mb-2">Datum: 12.07.2025 · Ort: Echterdingen</div>
                  <p class="text-[var(--color-text-muted)] text-sm">Jährliches Stadteilfest mit elektronischer Musik, welches ich jährlich organisiere und als DJ aufgetreten bin.</p>
                </div>
              </a>
            </article>
          </div>
        </div>
      </section>

    <!-- Radio Stations Section -->
   <section id="radio" class="section-padding bg-[var(--color-surface)]">
     <div class="max-w-7xl mx-auto">
       <div class="text-center mb-16 animate-on-scroll">
         <span
           class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
           >Radio</span
         >
         <h2 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-6">
           Resident DJ bei Web-Radios
         </h2>
         <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">
           Als Resident DJ bin ich regelmäßig bei verschiedenen Online-Radiostationen zu hören. 
           24/7 Electronic Music Streams mit Live-DJ-Sessions am Wochenende.
         </p>
       </div>

       <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- 365 FM Radio -->
          <a 
            href="https://www.365fmradio.de/" 
            target="_blank"
            class="bg-[var(--color-bg)] rounded-xl p-6 hover:scale-[1.02] transition-transform group"
          >
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 bg-[var(--color-primary)] rounded-lg flex items-center justify-center">
                <RadioIcon class="h-6 w-6 text-white" />
              </div>
              <div>
                <h3 class="font-play text-xl font-bold group-hover:text-[var(--color-secondary)] transition-colors">
                  365 FM Radio
                </h3>
                <span class="text-[var(--color-text-muted)] text-sm">Electronic Music 24/7</span>
              </div>
            </div>
            <p class="text-[var(--color-text-muted)] text-sm">
              365 FM Radio - elektronische Musik 24/7. Die heißesten Beats und die besten DJs direkt aus der Szene.
            </p>
          </a>

         <!-- CouchRadio -->
         <a 
           href="https://www.couchradio.ch/" 
           target="_blank"
           class="bg-[var(--color-bg)] rounded-xl p-6 hover:scale-[1.02] transition-transform group"
         >
           <div class="flex items-center gap-4 mb-4">
             <div class="w-12 h-12 bg-[var(--color-primary)] rounded-lg flex items-center justify-center">
               <RadioIcon class="h-6 w-6 text-white" />
             </div>
             <div>
               <h3 class="font-play text-xl font-bold group-hover:text-[var(--color-secondary)] transition-colors">
                 CouchRadio
               </h3>
               <span class="text-[var(--color-text-muted)] text-sm">Finest Deep House & Tech House</span>
             </div>
           </div>
           <p class="text-[var(--color-text-muted)] text-sm">
             CouchRadio - Welcome to the Stream! Finest Deep House, Progressive, Vocal, Tech House and more 24/7.
           </p>
         </a>
       </div>
       
       <!-- Ehrenurkunde 365 FM Radio -->
       <div class="mt-8">
         <a href="https://www.365fmradio.de/" target="_blank" class="block">
           <div class="bg-[var(--color-bg)] rounded-xl p-6 hover:scale-[1.02] transition-transform group">
             <div class="space-y-4">
               <p class="text-[var(--color-text-muted)] font-medium text-center">Ehrenmitglied beim Verein 365 FM Radio:</p>
               <img src="/img/463B18D9-C20F-486C-8787-7543C1D9931F.webp" alt="Ehrenurkunde 365 FM Radio" class="rounded-lg hover:scale-[1.02] transition-transform max-w-md mx-auto" />
             </div>
           </div>
         </a>
       </div>
     </div>
   </section>

    <!-- Resident Advisor Section -->
    <section class="section-padding bg-[var(--color-bg)]">
      <div class="max-w-7xl mx-auto">
        <div class="text-center animate-on-scroll">
          <div class="flex justify-center mb-4">
            <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center">
              <ResidentAdvisorIcon class="w-10 h-10" />
            </div>
          </div>
          <span
            class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
            >Resident Advisor</span
          >
          <h3 class="font-play text-2xl font-bold mt-4 mb-6">
            Mein Resident Advisor Profil
          </h3>
          <p class="text-[var(--color-text-muted)] mb-6">
            Hier findest du alle meine Gigs, eine kurze Biografie und einige
            Mixes.
            <a
              href="https://de.ra.co/dj/djhulk"
              target="_blank"
              class="text-[var(--color-primary)] underline"
              >Besuche mein Resident Advisor Profil</a
            >
          </p>
        </div>
      </div>
    </section>

    <!-- Spotify Section -->
    <section class="section-padding bg-[var(--color-surface)]">
      <div class="max-w-7xl mx-auto">
        <div class="text-center animate-on-scroll">
          <span
            class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"
