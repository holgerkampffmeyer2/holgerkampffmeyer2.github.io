            <button
              class="hidden md:flex absolute left-0 top-1/2 -translate-y-1/2 -ml-4 z-10 w-10 h-10 rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] items-center justify-center hover:border-[var(--color-primary)] transition-colors"
              data-events-prev
