---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProductGallery from '../../components/vermietung/ProductGallery.astro';
import TechnicalSpecs from '../../components/vermietung/TechnicalSpecs.astro';
import RentalIncludes from '../../components/vermietung/RentalIncludes.astro';
import RentalPricing from '../../components/vermietung/RentalPricing.astro';
import ExampleEvents from '../../components/vermietung/ExampleEvents.astro';

const pageTitle = "Partylicht & Gobo Moving Head - Vermietung | DJ Hulk";

const images = [
  "/img/vermietung/61UpvPLTkHL._AC_SL1500_.webp",
  "/img/vermietung/IMG_9114.webp",
  "/img/vermietung/IMG_9115.webp",
  "/img/vermietung/IMG_9119.webp",
  "/img/vermietung/IMG_9129.webp",
  "/img/vermietung/IMG_9139.webp",
  "/img/vermietung/IMG_9140.webp",
  "/img/vermietung/s-l1600.webp"
];

const specsMovingHead = {
  "Modell": "18 Prisma LED Spot 10 Gobo RGBW DMX",
  "DMX-Kanäle": "11/16",
  "LED": "RGBW 4-in-1",
  "Gobos": "10 Muster",
  "Prismen": "18-fach Prisma",
  "Steuerung": "Sound-zu-Licht, DMX, Automatikprogramme",
  "Abmessungen": "20.5 x 28 cm"
};

const specsPAR = {
  "Modell": "2x 270W 18 LED PAR RGBW",
  "LEDs": "18 x 15W RGBW 4-in-1",
  "DMX-Kanäle": "9",
  "Steuerung": "Sound-zu-Licht, DMX, Automatikprogramme",
  "Gehäuse": "Robustes Aluminium",
  "Abmessungen": "23 x 11.5 cm"
};

const specsStativ = {
  "Typ": "Flexibles T-Bar Stativ DJ Ständer",
  "Höhe": "100 - 180 cm",
  "Breite": "95 cm",
  "Montagepunkte": "4 für PAR-Lichter und Moving Heads"
};

const rentalIncludes = [
  "1x LED Spot Moving Head 18 Prisma",
  "2x LED PAR RGBW Strahler",
  "1x T-Bar Stativ",
  "DMX-Kabel nach Bedarf"
];

const events = [
  {
    title: "Geburtstagsfeier",
    description: "Spektakuläre Lichteffekte für Ihre Geburtstagsfeier. Die Moving Heads und PAR-Strahler sorgen für eine partyatmosphäre.",
    personCount: "bis 100 Personen"
  },
  {
    title: "Hochzeit",
    description: "Verleihen Sie Ihrer Hochzeit das gewisse Extra mit professioneller Lichttechnik. Perfekt für Tanzfläche und Ambientebeleuchtung.",
    personCount: "bis 100 Personen"
  },
  {
    title: "Firmenevent",
    description: "Beeindruckende Beleuchtung für Firmenfeiern, Jubiläen und Messen. Per DMX programmierbar für individuelle Lichtshows.",
    personCount: "bis 100 Personen"
  }
];
---

<Layout 
  title={pageTitle}
  description="Mieten Sie unsere Party-Lichtanlage mit Gobo Moving Head und LED PAR Strahlern. DMX-steuerbar mit Sound-zu-Licht Modus für Ihre Party."
  image="/img/vermietung/licht1.webp"
>
  <Navbar currentPage="/vermietung" />

  <!-- Breadcrumb -->
  <div class="breadcrumb-section">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="breadcrumb">
        <a href="/">Startseite</a>
        <span class="separator">/</span>
        <a href="/vermietung">Vermietung</a>
        <span class="separator">/</span>
        <span class="current">Partylicht & Moving Head</span>
      </nav>
    </div>
  </div>

  <!-- Header -->
  <section class="product-header section-padding pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Vermietung</span>
      <h1 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-4">Partylicht & Gobo Moving Head</h1>
      <p class="text-[var(--color-text-muted)] text-xl max-w-2xl">
        Leistungsfähige DMX-steuerbare Party-Lichtanlage mit 18 Prisma LED Moving Head, 
        zwei hellen 270W LED PAR Strahlern und flexiblem T-Bar Stativ. 
        Sound-zu-Licht oder eigene Programme per DMX.
      </p>
    </div>
  </section>

  <!-- 1. Bildergalerie -->
  <ProductGallery images={images} title="Partylicht & Moving Head" />

  <!-- 2. Preis & Kaution -->
  <RentalPricing price="ab 50€" deposit={100} />

  <!-- 3a. Technische Spezifikation Moving Head -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Technische Daten</span>
        <h2 class="font-play text-3xl md:text-4xl font-bold mt-4">Gobo Moving Head</h2>
      </div>
      <TechnicalSpecs specs={specsMovingHead} />
    </div>
  </section>

  <!-- 3b. Technische Spezifikation PAR Strahler -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-play text-3xl md:text-4xl font-bold mt-4">LED PAR Strahler</h2>
      </div>
      <TechnicalSpecs specs={specsPAR} />
    </div>
  </section>

  <!-- 3c. Technische Spezifikation Stativ -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-play text-3xl md:text-4xl font-bold mt-4">T-Bar Stativ</h2>
      </div>
      <TechnicalSpecs specs={specsStativ} />
    </div>
  </section>

  <!-- 4. Lieferumfang -->
  <RentalIncludes items={rentalIncludes} />

  <!-- 5. Beispielanwendungen -->
  <ExampleEvents events={events} />

  <!-- CTA Section -->
  <section class="cta-section section-padding bg-[var(--color-surface)]">
    <div class="max-w-4xl mx-auto text-center px-4">
      <h2 class="font-play text-3xl md:text-4xl font-bold mb-6">Interessiert an diesem Produkt?</h2>
      <p class="text-[var(--color-text-muted)] mb-8">
        Stellen Sie uns eine Anfrage für die Party-Lichtanlage oder lassen Sie sich beraten.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/vermietung#kontakt" class="btn-primary">Jetzt anfragen</a>
        <a href="/vermietung" class="btn-secondary">Zurück zur Übersicht</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .breadcrumb-section {
    padding-top: 120px;
    padding-bottom: 1rem;
    background: var(--color-bg);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }

  .breadcrumb a:hover {
    color: var(--color-secondary);
  }

  .breadcrumb .separator {
    color: var(--color-border);
  }

  .breadcrumb .current {
    color: var(--color-text);
  }

  .product-header {
    background: var(--color-bg);
    padding-bottom: 2rem;
  }

  .cta-section {
    text-align: center;
  }
</style>
