---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProductGallery from '../../components/vermietung/ProductGallery.astro';
import TechnicalSpecs from '../../components/vermietung/TechnicalSpecs.astro';
import RentalIncludes from '../../components/vermietung/RentalIncludes.astro';
import RentalPricing from '../../components/vermietung/RentalPricing.astro';
import ExampleEvents from '../../components/vermietung/ExampleEvents.astro';
import IncludedInPackages from '../../components/vermietung/IncludedInPackages.astro';
import ChevronRightIcon from '../../components/icons/ChevronRightIcon.astro';

const pageTitle = "Eurolite KLS Laser Bar & Nebelmaschine - Vermietung | DJ Hulk";

const faqs = [
  {
    question: "Brauche ich einen Laserschutzbeauftragten für die Laser Bar?",
    answer: "Nein, bei der Eurolite KLS Laser Bar handelt es sich um einen Laser der Klasse 2M. Dies bedeutet, dass kein Laserschutzbeauftragter erforderlich ist. Du solltest jedoch darauf achten, nicht direkt in den Laserstrahl zu blicken."
  },
  {
    question: "Wie sicher ist der Laser im Partybetrieb?",
    answer: "Der Laser der KLS Bar FX ist ein RG-Laser (Rot-Grün) der Klasse 2M. Er ist sicher für den Partygebrauch und Augensicherheit ist gewährleistet, solange man nicht absichtlich direkt in den Strahl schaut. Die Nutzung ist auch ohne spezielle Genehmigung erlaubt."
  },
  {
    question: "Welche Effekte bietet die Laser Bar?",
    answer: "Die Eurolite KLS Laser Bar FX vereint 4 Effekte in einem: 2 Derby-Beams mit drehenden Mustern, 2 LED-Spots für Flächeneffekte, 4 weiße Strobe-LEDs für Blitzlichter und einen Laser für spektakuläre Strahleneffekte."
  },
  {
    question: "Kann ich die Laser Bar auch ohne Nebelmaschine nutzen?",
    answer: "Ja, die Laser Bar funktioniert auch ohne Nebelmaschine. Allerdings kommen die Laserstrahlen und Effekte viel besser zur Geltung, wenn leichter Nebel die Luft vernebelt. Die 1200W Nebelmaschine kann optional dazugemietet werden."
  },
  {
    question: "Wie wird die Laser Bar gesteuert?",
    answer: "Die Steuerung erfolgt wahlweise per Sound-zu-Licht (automatisch auf Musik reagierend), über die mitgelieferte Fernbedienung oder per DMX. Der Sound-zu-Licht-Modus ist perfekt für Einsteiger geeignet."
  },
  {
    question: "Was tun, wenn die Party schon in 3 Tagen ist?",
    answer: "Ja, ich reagiere auch kurzfristig! Anfragen bis zu 2 Tagen vor der Veranstaltung sind meist noch möglich. Am besten rufst du mich direkt an unter 0171/1467491 für schnelle Abstimmung. Ich habe oft noch freie Geräte verfügbar."
  }
];

const includedInPackages = [
  { name: "Partypaket", url: "/vermietung/partypaket-stuttgart" },
  { name: "Veranstaltungspaket", url: "/vermietung/veranstaltungspaket-stuttgart" }
];

const images = [
  "/img/vermietung/eurolite-kls-laser-bar.webp",
  "/img/vermietung/eurolite-kls-laser-bar2.webp",
  "/img/vermietung/IMG_6642.webp",
  "/img/vermietung/uking_fogger-1200.webp"
];

const specsLaserBar = {
  "Modell": "Eurolite KLS Laser Bar FX",
  "Effekte": "2 Derbys, 2 LED Spots, 4 weiße Strobe-LEDs",
  "Laser": "RG, 2M",
  "Steuerung": "Sound-zu-Licht, Fernbedienung",
  "Stativ": "inklusive",
  "Besonderheiten": "Kein Laserschutzbeauftragter notwendig"
};

const specsNebelmaschine = {
  "Modell": "Nebelmaschine 1200W",
  "Leistung": "1200 W",
  "Ausstoß": "ca. 110 m³/min",
  "Fluid": "1L inklusive",
  "Steuerung": "Fernbedienung"
};

const rentalIncludes = [
  "1x Eurolite KLS Laser Bar FX",
  "1x Nebelmaschine 1200W (optional)",
  "1x Stativ",
  "1x Fernbedienung",
  "1L Nebelfluid (bei Nebelmaschine)"
];

const events = [
  {
    title: "Geburtstagsfeier",
    description: "Die Kombination aus Laser-Effekten und Nebel sorgt für eine tolle Party-Atmosphäre. Perfekt für Geburtstagsfeiern.",
    personCount: "bis 100 Personen"
  },
  {
    title: "Hochzeit",
    description: "Verleih deiner Hochzeit das gewisse Extra mit spektakulären Laser-Show-Effekten.",
    personCount: "bis 100 Personen"
  },
  {
    title: "Firmenfeier",
    description: "Professionelle Laserlichtanlage für Firmenfeiern und Events. Kein Laserschutzbeauftragter erforderlich.",
    personCount: "bis 100 Personen"
  }
];
---

<Layout 
  title={pageTitle}
  description="Miete die Eurolite KLS Laser Bar FX mit 1200W Nebelmaschine. Sound-zu-Licht Steuerung für deine Party."
  image="/img/vermietung/eurolite-kls-laser-bar.webp"
>
  <Navbar currentPage="/vermietung" />

  <!-- Breadcrumb -->
  <div class="breadcrumb-section">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="breadcrumb">
        <a href="/">Startseite</a>
        <span class="separator">/</span>
        <a href="/vermietung">Vermietung</a>
        <span class="separator">/</span>
        <span class="current">Eurolite KLS Laser Bar</span>
      </nav>
    </div>
  </div>

  <!-- Header -->
  <section class="product-header section-padding pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Vermietung</span>
      <h1 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-4">Eurolite KLS Laser Bar FX</h1>
      <p class="text-[var(--color-text-muted)] text-xl max-w-2xl">
        Die EUROLITE LED KLS Laser Bar FX ist ein kompaktes 4in1-Lichtset mit vielen Einsatzmöglichkeiten:  mit 2 Derbys, 2 LED Spots, 4 weißen Strobe-LEDs und Laser (RG, 2M) sorgt die Lichtanlage für eine beeindruckende Lichtshow. 
        Optional mit 1200W Nebelmaschine. Kein Laserschutzbeauftragter notwendig!
      </p>
    </div>
  </section>

  <!-- 1. Bildergalerie -->
  <ProductGallery images={images} title="Eurolite KLS Laser Bar" />

  <!-- 2. Preis & Kaution -->
  <RentalPricing price="ab 50€" deposit={100} />

  <!-- 3a. Technische Spezifikation Laser Bar -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Technische Daten</span>
        <h2 class="font-play text-3xl md:text-4xl font-bold mt-4">Eurolite KLS Laser Bar FX</h2>
      </div>
      <TechnicalSpecs specs={specsLaserBar} />
    </div>
  </section>

  <!-- 3b. Technische Spezifikation Nebelmaschine -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-play text-3xl md:text-4xl font-bold mt-4">Nebelmaschine 1200W</h2>
      </div>
      <TechnicalSpecs specs={specsNebelmaschine} />
    </div>
  </section>

  <!-- 4. Lieferumfang -->
  <RentalIncludes items={rentalIncludes} />

  <!-- 5. Beispielanwendungen -->
  <ExampleEvents events={events} />

  <!-- FAQ -->
  <section class="section-padding">
    <div class="max-w-4xl mx-auto px-4">
      <h3 class="font-play text-2xl md:text-3xl font-bold text-center mb-10">
        Häufig gestellte Fragen
      </h3>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="bg-[var(--color-surface)] rounded-xl p-4 cursor-pointer group">
            <summary class="font-bold cursor-pointer flex items-center gap-3 list-none">
              <span class="w-6 h-6 bg-orange-500/20 rounded flex items-center justify-center text-orange-500 group-open:rotate-90 transition-transform">
                <ChevronRightIcon class="w-3 h-3" />
              </span>
              {faq.question}
            </summary>
            <p class="text-[var(--color-text-muted)] mt-3 ml-9">
              {faq.answer}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section section-padding bg-[var(--color-surface)]">
    <div class="max-w-4xl mx-auto text-center px-4">
      <h2 class="font-play text-3xl md:text-4xl font-bold mb-2">Interessiert an diesem Produkt?</h2>
      <p class="text-[var(--color-text-muted)] mb-6">
        Stell uns eine Anfrage für die Eurolite KLS Laser Bar oder lass dich beraten.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/vermietung#kontakt" class="btn-primary">Jetzt anfragen</a>
        <a href="/vermietung" class="btn-secondary">Zurück zur Übersicht</a>
      </div>
      <IncludedInPackages packages={includedInPackages} />
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .breadcrumb-section {
    padding-top: 120px;
    padding-bottom: 1rem;
    background: var(--color-bg);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }

  .breadcrumb a:hover {
    color: var(--color-secondary);
  }

  .breadcrumb .separator {
    color: var(--color-border);
  }

  .breadcrumb .current {
    color: var(--color-text);
  }

  .product-header {
    background: var(--color-bg);
    padding-bottom: 2rem;
  }

  .cta-section {
    text-align: center;
  }
</style>
