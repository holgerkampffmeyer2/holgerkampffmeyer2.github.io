---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProductGallery from '../../components/vermietung/ProductGallery.astro';
import TechnicalSpecs from '../../components/vermietung/TechnicalSpecs.astro';
import RentalIncludes from '../../components/vermietung/RentalIncludes.astro';
import RentalPricing from '../../components/vermietung/RentalPricing.astro';
import ExampleEvents from '../../components/vermietung/ExampleEvents.astro';

const pageTitle = "LD Maui 28 G3 - Vermietung | DJ Hulk";

const images = [
  "/img/vermietung/ldmaui3.webp",
  "/img/vermietung/LDMAUI28G3_1_kl.webp",
  "/img/vermietung/ldmaui2.webp",
  "/img/vermietung/ld-3.webp",
  "/img/vermietung/IMG_4594.webp",
  "/img/vermietung/IMG_3952.webp",
  "/img/vermietung/IMG_4252.webp",
  "/img/vermietung/IMG_4722.webp",
  "/img/vermietung/IMG_6054.webp",
  "/img/vermietung/IMG_6196.webp",
  "/img/vermietung/IMG_6267.webp",
  "/img/vermietung/IMG_7142.webp"
];

const specs = {
  "Peak-Leistung": "2060 W",
  "RMS-Leistung": "1030 W",
  "Max. SPL": "127 dB",
  "Frequenzbereich": "37 Hz - 20 kHz",
  "Subwoofer": '12" (305 mm)',
  "Midrange": "12 x 3.5\"",
  "Hochtöner": "2 x 1\"",
  "Dispersion": "120° x 30°",
  "Bluetooth": "5.0 mit AAC",
  "Gewicht": "35.4 kg",
  "Abmessungen Subwoofer": "370 x 527 x 472 mm",
  "Gesamthöhe": "2052 mm"
};

const rentalIncludes = [
  "2x LD Maui 28 G3 Säulensystem",
  "2x Stromkabel",
  "2x XLR Kabel 5m",
  "Transporttaschen"
];

const events = [
  {
    title: "Hochzeit",
    description: "Perfekt für die musikalische Untermalung deiner Hochzeitsfeier mit bis zu 150 Gästen. Kraftvoller und klarer Sound für Musik und Durchsagen.",
    personCount: "bis 150 Personen"
  },
  {
    title: "Firmenfeier",
    description: "Ideal für Betriebsfeiern, Jubiläen und Firmenevents. Professioneller Sound für Reden, Präsentationen und musikalische Untermalung.",
    personCount: "bis 150 Personen"
  },
  {
    title: "Vereinsfeier",
    description: "Egal ob Sportverein, Musikverein oder sonstige Vereinsfeier - der kraftvolle Sound sorgt für beste Stimmung bei allen Gästen.",
    personCount: "bis 150 Personen"
  }
];
---

<Layout 
  title={pageTitle}
  description="Miete das LD Maui 28 G3 Säulensystem für deine Party, Hochzeit oder Firmenfeier. Professionelle PA-Anlage mit 2060W für bis zu 150 Personen."
  image="/img/vermietung/ldmaui3.webp"
>
  <Navbar currentPage="/vermietung" />

  <!-- Breadcrumb -->
  <div class="breadcrumb-section">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="breadcrumb">
        <a href="/">Startseite</a>
        <span class="separator">/</span>
        <a href="/vermietung">Vermietung</a>
        <span class="separator">/</span>
        <span class="current">LD Maui 28 G3</span>
      </nav>
    </div>
  </div>

  <!-- Header -->
  <section class="product-header section-padding pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Vermietung</span>
      <h1 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-4">LD Maui 28 G3</h1>
      <p class="text-[var(--color-text-muted)] text-xl max-w-2xl">
        Professionelles Säulen-PA-System mit kraftvollem Sound für bis zu 150 Personen. 
        Kompaktes Plug & Play System mit erstklassiger Klangqualität.
      </p>
    </div>
  </section>

  <!-- 1. Bildergalerie -->
  <ProductGallery images={images} title="LD Maui 28 G3" />

  <!-- 2. Preis & Kaution -->
  <RentalPricing price="ab 100€" deposit={200} />

  <!-- 3. Technische Spezifikation -->
  <TechnicalSpecs specs={specs} />

  <!-- 4. Lieferumfang -->
  <RentalIncludes items={rentalIncludes} />

  <!-- 5. Beispielanwendungen -->
  <ExampleEvents events={events} />

  <!-- CTA Section -->
  <section class="cta-section section-padding bg-[var(--color-surface)]">
    <div class="max-w-4xl mx-auto text-center px-4">
      <h2 class="font-play text-3xl md:text-4xl font-bold mb-6">Interessiert an diesem Produkt?</h2>
      <p class="text-[var(--color-text-muted)] mb-8">
        Stell uns eine Anfrage für die LD Maui 28 G3 oder lass dich beraten.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/vermietung#kontakt" class="btn-primary">Jetzt anfragen</a>
        <a href="/vermietung" class="btn-secondary">Zurück zur Übersicht</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .breadcrumb-section {
    padding-top: 120px;
    padding-bottom: 1rem;
    background: var(--color-bg);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }

  .breadcrumb a:hover {
    color: var(--color-secondary);
  }

  .breadcrumb .separator {
    color: var(--color-border);
  }

  .breadcrumb .current {
    color: var(--color-text);
  }

  .product-header {
    background: var(--color-bg);
    padding-bottom: 2rem;
  }

  .cta-section {
    text-align: center;
  }
</style>
