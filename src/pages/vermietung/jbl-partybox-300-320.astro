---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProductGallery from '../../components/vermietung/ProductGallery.astro';
import TechnicalSpecs from '../../components/vermietung/TechnicalSpecs.astro';
import RentalIncludes from '../../components/vermietung/RentalIncludes.astro';
import RentalPricing from '../../components/vermietung/RentalPricing.astro';
import ExampleEvents from '../../components/vermietung/ExampleEvents.astro';
import IncludedInPackages from '../../components/vermietung/IncludedInPackages.astro';
import ChevronRightIcon from '../../components/icons/ChevronRightIcon.astro';

const pageTitle = "JBL Partybox 300/320 - Vermietung | DJ Hulk";

const faqs = [
  {
    question: "Wie lange hält der Akku der JBL Partybox?",
    answer: "Die JBL Partybox 300 und 320 bieten bis zu 18 Stunden Akkulaufzeit. Die tatsächliche Laufzeit hängt von der Lautstärke und der Nutzung der Lichteffekte ab. Bei voller Lautstärke mit Light Show sind es ca. 6-8 Stunden."
  },
  {
    question: "Kann ich zwei Partyboxen miteinander verbinden?",
    answer: "Ja! Im Paket ist ein Verbindungskabel (5M) fürdie Verbindung der zwei Boxen enthalten. Das ist perfekt für größere Räume oder wenn du mehr Power brauchst."
  },
  {
    question: "Wie spiele ich Musik auf den Partyboxen ab?",
    answer: "Du hast mehrere Möglichkeiten: Bluetooth (von Smartphone/Tablet), USB-Stick, 3,5mm Klinke (AUX) oder sogar ein Mikrofon/Gitarre direkt anschließen. Bei Bedarf lege ich ein passendes Kabel für den Anschluss eines Laptops bei."
  },
  {
    question: "Sind die Boxen wasserdicht?",
    answer: "Die JBL Partybox 320 ist nach IPX4 spritzwassergeschützt und kann daher auch im Freien bei leichtem Regen genutzt werden. Die Partybox 300 ist nicht wasserdicht und sollte vor Nässe geschützt werden."
  },
  {
    question: "Wie groß ist der Lieferumfang?",
    answer: "Im Mietpaket enthalten sind: 1x JBL Partybox 300, 1x JBL Partybox 320, 2x Stromkabel und 1x Verbindungskabel (5m) für die Kopplung der 2 Boxen. Bei Bedarf lege ich noch ein Verbindungskabel für die Zuspielung von Musik über einen Laptops bei. Alles was du für den Start brauchst!"
  },
  {
    question: "Was tun, wenn die Party schon in 3 Tagen ist?",
    answer: "Ja, ich reagiere auch kurzfristig! Anfragen bis zu 2 Tagen vor der Veranstaltung sind meist noch möglich. Am besten rufst du mich direkt an unter 0171/1467491 für schnelle Abstimmung. Ich habe oft noch freie Geräte verfügbar."
  }
];

const includedInPackages = [
  { name: "Partypaket", url: "/vermietung/partypaket-stuttgart" }
];

const images = [
  "/img/vermietung/jbl-set1.webp",
  "/img/vermietung/jbl-set2.webp",
  "/img/vermietung/partybox-300_kl.webp",
  "/img/vermietung/jblpartyboxen.webp",
  "/img/vermietung/jblpartyboxen2.webp"
];

const siteUrl = "https://holger-kampffmeyer.de";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "JBL Partybox 300 + 320 Set Vermietung",
  "description": "Leihe dieses leistungsstarke Partyboxen‑Set (2×240W) mit Akku, Light‑Show und Bluetooth – ideal für private Feiern bis 80 Personen.",
  "image": [
    siteUrl + images[0],
    siteUrl + images[1]
  ],
  "provider": {
    "@type": "Person",
    "name": "Holger Kampffmeyer",
    "telephone": "+49-171-1467491",
    "url": "https://holger-kampffmeyer.de"
  },
  "offers": {
    "@type": "Offer",
    "url": "https://holger-kampffmeyer.de/vermietung/jbl-partybox-300-320",
    "price": "80",
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://holger-kampffmeyer.de/"},
    {"@type": "ListItem", "position": 2, "name": "Vermietung", "item": "https://holger-kampffmeyer.de/vermietung"},
    {"@type": "ListItem", "position": 3, "name": "JBL Partybox 300/320"}
  ]
};

const specs = {
  "Ausgangsleistung": "2x 240 W",
  "Frequenzbereich": "40 Hz - 20 kHz",
  "Treiber": '2x 6.5" Woofer + 2x 1" Tweeter pro Box',
  "Bluetooth": "Ja",
  "Akku-Laufzeit": "bis 18 Stunden",
  "Gewicht": "15.8 kg / 16.5 kg",
  "Abmessungen": "31 x 69 x 32 cm / 33.5 x 67 x 38.5 cm",
  "Eingänge": "USB, Aux, Mikrofon/Gitarre",
  "Besonderheiten": "Light Show, Kopplung, IPX4 (nur 320)"
};

const rentalIncludes = [
  "1x JBL Partybox 300",
  "1x JBL Partybox 320",
  "2x Stromkabel",
  "1x Verbindungskabel 5m"
];

const events = [
  {
    title: "Party",
    description: "Leistungsstarke Partylautsprecher mit JBL-Soundqualität und dynamischen Lichteffekten. Perfekt für Geburtstagsfeiern und private Feiern.",
    personCount: "50-80 Personen"
  },
  {
    title: "Vereinsfeier",
    description: "Kraftvoller Sound für größere Feiern im Vereinsheim oder Festzelt. Zuspielung per Bluetooth oder Kabel.",
    personCount: "50-80 Personen"
  },
  {
    title: "Firmenfeier",
    description: "Professionelle Soundanlage für Betriebsfeiern und Jubiläen. Beide Boxen koppelbar für Stereo-Sound.",
    personCount: "50-80 Personen"
  }
];
---

<Layout 
  title={pageTitle}
  description="Miete das Set JBL Partybox 300 + 320 für deine Party, Geburtstagsfeier oder Firmenfeier. 2x 240W mit Akku, Light Show und TWS-Kopplung für bis zu 80 Personen."
  image="/img/vermietung/partybox-300_kl.webp"
  jsonLd={[serviceSchema, breadcrumbSchema]}
>
  <Navbar currentPage="/vermietung" />

  <!-- Breadcrumb -->
  <div class="breadcrumb-section">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="breadcrumb">
        <a href="/">Startseite</a>
        <span class="separator">/</span>
        <a href="/vermietung">Vermietung</a>
        <span class="separator">/</span>
        <span class="current">JBL Partybox 300/320</span>
      </nav>
    </div>
  </div>

  <!-- Header -->
  <section class="product-header section-padding pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Vermietung</span>
      <h1 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-4">JBL Partybox 300/320</h1>
      <p class="text-[var(--color-text-muted)] text-xl max-w-2xl">
        Miete unser Set aus JBL Partybox 300 und Stage 320 für deine nächste Party. Die JBL PartyBoxen sind mobile Party-Lautsprecher mit 240 W RMS-Leistung, tiefem Bass von 40 Hz und bis zu 18 Stunden Akkulaufzeit.
        Dank Bluetooth, USB- und Klinkeneingängen kannst du deine Musik flexibel abspielen. Die integrierte Licht Show sorgt für die richtige Stimmung auf deiner Feier. <br />
        Perfekt für bis zu 80 Personen.
      </p>
      
    </div>
  </section>

  <!-- 1. Bildergalerie -->
  <ProductGallery images={images} title="JBL Partybox 300/320" />

  <!-- Demo Video -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-8">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase"><Video></Video></span>
        <h2 class="font-play text-3xl font-bold mt-2">Sound-Check der JBL Partyboxen</h2>
        <p class="text-[var(--color-text-muted)] mt-2">Eindruck der JBL Partyboxen 300 und 320 in Aktion</p>
      </div>
      <div class="aspect-video rounded-xl overflow-hidden bg-black">
        <iframe 
          src="https://www.youtube.com/embed/Ivch0DqKkW0" 
          title="JBL Partybox Demo"
          class="w-full h-full"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- 2. Preis & Kaution -->
  <RentalPricing price="ab 80€" deposit={150} />

  <!-- 3. Technische Spezifikation -->
  <TechnicalSpecs specs={specs} />

  <!-- 4. Lieferumfang -->
  <RentalIncludes items={rentalIncludes} />

  <!-- 5. Beispielanwendungen -->
  <ExampleEvents events={events} />

  <!-- FAQ -->
  <section class="section-padding">
    <div class="max-w-4xl mx-auto px-4">
      <h3 class="font-play text-2xl md:text-3xl font-bold text-center mb-10">
        Häufig gestellte Fragen
      </h3>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="bg-[var(--color-surface)] rounded-xl p-4 cursor-pointer group">
            <summary class="font-bold cursor-pointer flex items-center gap-3 list-none">
              <span class="w-6 h-6 bg-orange-500/20 rounded flex items-center justify-center text-orange-500 group-open:rotate-90 transition-transform">
                <ChevronRightIcon class="w-3 h-3" />
              </span>
              {faq.question}
            </summary>
            <p class="text-[var(--color-text-muted)] mt-3 ml-9">
              {faq.answer}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section section-padding bg-[var(--color-surface)]">
    <div class="max-w-4xl mx-auto text-center px-4">
      <h2 class="font-play text-3xl md:text-4xl font-bold mb-2">Interessiert an diesem Produkt?</h2>
      <p class="text-[var(--color-text-muted)] mb-6">
        Stell uns eine Anfrage für das JBL Partybox Set oder lass dich beraten.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/vermietung#kontakt" class="btn-primary">Jetzt anfragen</a>
        <a href="/vermietung" class="btn-secondary">Zurück zur Übersicht</a>
      </div>
      <IncludedInPackages packages={includedInPackages} />
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .breadcrumb-section {
    padding-top: 120px;
    padding-bottom: 1rem;
    background: var(--color-bg);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }

  .breadcrumb a:hover {
    color: var(--color-secondary);
  }

  .breadcrumb .separator {
    color: var(--color-border);
  }

  .breadcrumb .current {
    color: var(--color-text);
  }

  .product-header {
    background: var(--color-bg);
    padding-bottom: 2rem;
  }

  .cta-section {
    text-align: center;
  }
</style>
