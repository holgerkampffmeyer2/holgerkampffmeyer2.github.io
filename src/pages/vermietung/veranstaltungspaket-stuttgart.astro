---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProductGallery from '../../components/vermietung/ProductGallery.astro';
import PackageContents from '../../components/vermietung/PackageContents.astro';
import RentalPricing from '../../components/vermietung/RentalPricing.astro';
import ExampleEvents from '../../components/vermietung/ExampleEvents.astro';
import Testimonials from '../../components/vermietung/Testimonials.astro';
import ChevronRightIcon from '../../components/icons/ChevronRightIcon.astro';

const pageTitle = "Veranstaltungspaket Stuttgart - Eventtechnik Miete | DJ Hulk";

const faqs = [
  {
    question: "Was unterscheidet das Veranstaltungspaket vom DJ-Paket?",
    answer: "Das Veranstaltungspaket enthält: 2x LD Maui 28 G3, Yamaha MG6 Mischpult, Eurolite KLS Laser Bar, AF-150 Nebelmaschine, 2x LED Spot Moving Head, Mikrofon und 4x LED PAR Strahler. Das DJ-Paket enthält stattdessen die LED BossFX Pro und einen Moving Head. Das Veranstaltungspaket hat mehr Licht-Komponenten."
  },
  {
    question: "Wie groß darf die Veranstaltung sein?",
    answer: "Das Veranstaltungspaket eignet sich für Veranstaltungen mit bis zu 150 Personen. Die LD Maui 28 G3 liefert mit 2060W genug Leistung auch für größere Räume. Die Lichtanlage mit Laser, Moving Heads und PAR Strahlern sorgt für eine beeindruckende Show."
  },
  {
    question: "Kann ich die Technik auch ohne DJ nutzen?",
    answer: "Ja, das Paket kannst du auch ohne DJ nutzen. Das Yamaha Mischpult ermöglicht dir den Anschluss mehrerer Audioquellen (Laptop, Mikrofon, etc.). Die Lichtanlage läuft im Sound-zu-Licht-Modus automatisch oder kann per DMX gesteuert werden."
  },
  {
    question: "Ist das Yamaha Mischpult im Paket enthalten?",
    answer: "Ja, das Yamaha MG6 6-Kanal Mischpult ist im Veranstaltungspaket enthalten. Es ermöglicht dir die flexible Steuerung verschiedener Audioquellen und bietet die Möglichkeit, Mikrofone und Musikquellen separat zu mischen."
  },
  {
    question: "Wie funktioniert die Lieferung und Abholung?",
    answer: "Du kannst die Technik selbst in Leinfelden-Echterdingen abholen oder wir liefern sie gegen Aufpreis direkt zu deinem Veranstaltungsort. Bei der Abholung geben wir dir eine ausführliche Einweisung in Aufbau und Bedienung."
  },
  {
    question: "Was tun, wenn die Party schon in 3 Tagen ist?",
    answer: "Ja, ich reagiere auch kurzfristig! Anfragen bis zu 2 Tagen vor der Veranstaltung sind meist noch möglich. Am besten rufst du mich direkt an unter 0171/1467491 für schnelle Abstimmung. Ich habe oft noch freie Geräte verfügbar."
  }
];

const images = [
  "/img/vermietung/ldmaui3.webp",
  "/img/vermietung/LDMAUI28G3_1_kl.webp",
  "/img/vermietung/ldmaui2.webp",
  "/img/vermietung/ld-3.webp",
  "/img/vermietung/IMG_4594.webp",
  "/img/vermietung/yamaha_mg6_kl.webp",
  "/img/vermietung/eurolite-kls-laser-bar.webp",
  "/img/vermietung/eurolite-kls-laser-bar2.webp",
  "/img/vermietung/stairville-af-150-fog-machine.webp",
  "/img/vermietung/stairville-af-150-fog-machine-1.webp",
  "/img/vermietung/IMG_9114.webp",
  "/img/vermietung/IMG_7142.webp",
  "/img/vermietung/IMG_9130.webp",
  "/img/vermietung/IMG_9131.webp"
];

const packageItems = [
  { name: "2x LD Maui 28 G3 Säulensystem", detailPage: "/vermietung/ld-maui-28g3" },
  { name: "Yamaha MG6 6-Kanal Mischpult" },
  { name: "Eurolite KLS Laser Bar", detailPage: "/vermietung/kls-laser-bar" },
  { name: "Stairville AF-150 Nebelmaschine", detailPage: "/vermietung/led-bossfx-nebelmaschine" },
  { name: "2x LED Spot Moving Head" },
  { name: "Mikrofon inkl. Kabel" },
  { name: "4x LED PAR Strahler" },
  { name: "Stromkabel und alle notwendigen Anschlusskabel mit dabei" }
];

const events = [
  {
    title: "Hochzeit",
    description: "Das ideale Paket für Hochzeitsfeiern bis 150 Gäste. Professioneller Sound für Musik und Reden, kombiniert mit einer beeindruckenden Lichtshow.",
    personCount: "bis 150 Personen"
  },
  {
    title: "Firmenfeier",
    description: "Perfekt für Betriebsfeiern, Jubiläen und Firmenevents. Leistungsstarke Anlage für klare Durchsagen und musikalische Untermalung.",
    personCount: "bis 150 Personen"
  },
  {
    title: "Vereinsfeier",
    description: "Egal ob Sportverein, Musikverein oder sonstige Vereinsfeier - das Veranstaltungspaket liefert professionellen Sound und Licht für jede Größe.",
    personCount: "bis 150 Personen"
  },
  {
    title: "Gartenfest",
    description: "Auch für größere Gartenfeste mit bis zu 150 Gästen geeignet. Wetterfeste Aufstellung und kraftvoller Sound auch im Außenbereich.",
    personCount: "bis 150 Personen"
  }
];

const packageFeatures = [
  "Leistungsstarkes Komplettpaket für mittlere Feiern",
  "LD Maui 28 G3 - professionelles Säulensystem mit erstklassigem Sound",
  "Yamaha 6-Kanal Mischpult für flexible Audio-Steuerung",
  "KLS Laser Bar mit spektakulären Licht- und Lasereffekten (kein Laserschutzbeauftragter nötig)",
  "Nebelmaschine für atmosphärische Lichtwirkung",
  "2 Moving Heads für dynamische Lichtshows",
  "Mikrofon für Durchsagen und Ansprachen",
  "4 LED PAR Strahler für atmosphärische Ambientebeleuchtung",
  "Alle notwendigen Strom- und Anschlusskabel inklusive - einfacher Aufbau",
  "Passt in einen Kombi oder Kleinwagen mit umgeklappter Rückbank"
];

const siteUrl = "https://holger-kampffmeyer.de";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Veranstaltungspaket Stuttgart Vermietung",
  "description": "Miete das Veranstaltungspaket für dein Event in Stuttgart. Komplette Eventtechnik mit LD Maui Soundanlage, Licht, Nebel und Moving Heads für bis zu 150 Personen.",
  "image": [
    siteUrl + images[0],
    siteUrl + images[1]
  ],
  "provider": {
    "@type": "Person",
    "name": "Holger Kampffmeyer",
    "telephone": "+49-171-1467491",
    "url": "https://holger-kampffmeyer.de"
  },
  "offers": {
    "@type": "Offer",
    "url": "https://holger-kampffmeyer.de/vermietung/veranstaltungspaket-stuttgart",
    "price": "180",
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock"
  }
};
---

<Layout 
  title={pageTitle}
  description="Miete das Veranstaltungspaket für dein Event in Stuttgart. Komplette Eventtechnik mit LD Maui Soundanlage, Licht, Nebel und Moving Heads für bis zu 150 Personen."
  image="/img/vermietung/ldmaui3.webp"
  jsonLd={serviceSchema}
>
  <Navbar currentPage="/vermietung" />

  <!-- Breadcrumb -->
  <div class="breadcrumb-section">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="breadcrumb">
        <a href="/">Startseite</a>
        <span class="separator">/</span>
        <a href="/vermietung">Vermietung</a>
        <span class="separator">/</span>
        <span class="current">Veranstaltungspaket Stuttgart</span>
      </nav>
    </div>
  </div>

  <!-- Header -->
  <section class="product-header section-padding pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Vermietung</span>
      <h1 class="font-play text-4xl md:text-5xl font-bold mt-4 mb-4">Veranstaltungspaket Stuttgart</h1>
      <p class="text-[var(--color-text-muted)] text-xl max-w-2xl">
        Das professionelle Veranstaltungspaket für mittlere Feiern bis ca. 150 Personen. 
        Hochwertige Technik mit LD Maui Soundanlage, Licht, Nebel und Moving Heads.
      </p>
    </div>
  </section>

  <!-- Package Highlights -->
  <section class="section-padding bg-[var(--color-surface)]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Highlights</span>
        <h2 class="font-play text-3xl md:text-4xl font-bold mt-4">Die Besonderheiten des Veranstaltungspakets</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {packageFeatures.map((feature) => (
          <div class="bg-[var(--color-bg)] p-6 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-secondary)] transition-all duration-300">
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-secondary)] text-2xl">✓</span>
              <p class="text-[var(--color-text)]">{feature}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 1. Bildergalerie -->
  <ProductGallery images={images} title="Veranstaltungspaket" />

  <!-- Demo Video -->
  <section class="section-padding bg-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-8">
        <span class="text-[var(--color-secondary)] text-lg tracking-widest uppercase">Video</span>
        <h2 class="font-play text-3xl font-bold mt-2">Sound-Check PA-Anlage</h2>
        <p class="text-[var(--color-text-muted)] mt-2">Eindruck der LD Maui 28 G3 in Aktion</p>
      </div>
      <div class="aspect-video rounded-xl overflow-hidden bg-black">
        <iframe 
          src="https://www.youtube.com/embed/vE5PQ7IUdrg" 
          title="LD Maui 28 G3 Demo"
          class="w-full h-full"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- 2. Preis & Kaution -->
  <RentalPricing price="ab 180€" deposit={400} />

  <!-- 3. Enthalten im Paket -->
  <PackageContents title="Enthalten im Veranstaltungspaket" items={packageItems} />

  <!-- 4. Beispielanwendungen -->
  <ExampleEvents events={events} />

  <!-- FAQ -->
  <section class="section-padding">
    <div class="max-w-4xl mx-auto px-4">
      <h3 class="font-play text-2xl md:text-3xl font-bold text-center mb-10">
        Häufig gestellte Fragen
      </h3>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="bg-[var(--color-surface)] rounded-xl p-4 cursor-pointer group">
            <summary class="font-bold cursor-pointer flex items-center gap-3 list-none">
              <span class="w-6 h-6 bg-orange-500/20 rounded flex items-center justify-center text-orange-500 group-open:rotate-90 transition-transform">
                <ChevronRightIcon class="w-3 h-3" />
              </span>
              {faq.question}
            </summary>
            <p class="text-[var(--color-text-muted)] mt-3 ml-9">
              {faq.answer}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section section-padding bg-[var(--color-surface)]">
    <div class="max-w-4xl mx-auto text-center px-4">
      <h2 class="font-play text-3xl md:text-4xl font-bold mb-6">Interessiert an diesem Paket?</h2>
      <p class="text-[var(--color-text-muted)] mb-8">
        Stell uns eine Anfrage für das Veranstaltungspaket oder lass dich beraten.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/vermietung#kontakt" class="btn-primary">Jetzt anfragen</a>
        <a href="/vermietung" class="btn-secondary">Zurück zur Übersicht</a>
      </div>
    </div>
  </section>

  <Testimonials />

  <Footer />
</Layout>

<style>
  .breadcrumb-section {
    padding-top: 120px;
    padding-bottom: 1rem;
    background: var(--color-bg);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }

  .breadcrumb a:hover {
    color: var(--color-secondary);
  }

  .breadcrumb .separator {
    color: var(--color-border);
  }

  .breadcrumb .current {
    color: var(--color-text);
  }

  .product-header {
    background: var(--color-bg);
    padding-bottom: 2rem;
  }

  .cta-section {
    text-align: center;
  }
</style>
