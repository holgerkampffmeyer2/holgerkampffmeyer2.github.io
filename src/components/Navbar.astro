---
import ChevronDownIcon from "./icons/ChevronDownIcon.astro";
import MenuIcon from "./icons/MenuIcon.astro";

interface Props {
  currentPage?: string;
}

const { currentPage = 'home' } = Astro.props;

const navItems = [
  { 
    href: '/', 
    label: 'Home' ,
    hasDropdown: true,
    items: [
      { href: '/#vermietung', label: 'Vermietung' },
      { href: '/#djing', label: 'DJ Hulk' }
    ]
  },
  { 
    href: '/djhulk-electronic-music', 
    label: 'DJing',
    hasDropdown: true,
    items: [
      { href: '/dj/videos', label: 'Videos' },
      { href: '/dj/mixes', label: 'Mixes' },
      { href: '/dj/em3f', label: 'Fotos' }
    ]
  },
  { 
    href: '/vermietung', 
    label: 'Vermietung',
    hasDropdown: true,
    items: [
      { href: '/vermietung/partypaket-stuttgart', label: 'Partypaket' },
      { href: '/vermietung/veranstaltungspaket-stuttgart', label: 'Veranstaltungspaket' },
      { href: '/vermietung/djpaket-fildern', label: 'DJ-Paket' },
      { href: '/vermietung/ld-maui-28g3', label: 'LD Maui 28 G3' },
      { href: '/vermietung/jbl-partybox-300-320', label: 'JBL Partybox 300/320' },
      { href: '/vermietung/partylicht-moving-head', label: 'Partylicht & Moving Head' },
      { href: '/vermietung/led-bossfx-nebelmaschine', label: 'LED BossFX & Nebelmaschine' },
      { href: '/vermietung/kls-laser-bar', label: 'KLS Laser Bar' }
    ]
  },
  { href: '/links', label: 'Links' },
  { href: '/work', label: 'Work' },
  { href: '/impressum', label: 'Impressum' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-bg)]/90 backdrop-blur-md border-b border-[var(--color-border)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-3">
        <img src="/img/djhulk_logo.png" alt="DJ Hulk Logo" class="h-12" />
        <span class="font-play text-xl font-bold hidden sm:block">Holger Kampffmeyer DJ Dienstleistungen</span>
      </a>
      
      <!-- Desktop Menu -->
      <div class="desktop-menu hidden md:flex items-center space-x-6">
        {navItems.map(item => (
          item.hasDropdown ? (
            <div class="relative group">
              <a href={item.href} class="nav-link flex items-center gap-1">
                {item.label}
                <ChevronDownIcon class="h-4 w-4" />
              </a>
              <div class="absolute top-full left-0 mt-2 w-48 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                {item.items?.map(subItem => (
                  <a href={subItem.href} class="block px-4 py-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] hover:bg-[var(--color-bg)] first:rounded-t-lg last:rounded-b-lg">
                    {subItem.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a 
              href={item.href} 
              class:list={[
                "nav-link",
                { "active": currentPage === item.href || (currentPage.startsWith('/dj') && item.href === '/djhulk-electronic-music') }
              ]}
            >
              {item.label}
            </a>
          )
        ))}
      </div>
      
      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden text-[var(--color-text)] p-2">
        <MenuIcon class="h-8 w-8" />
      </button>
    </div>
  </div>
  
  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-[var(--color-surface)] border-t border-[var(--color-border)]">
    <div class="px-4 py-4 space-y-3">
      {navItems.map(item => (
        <a href={item.href} class="block nav-link py-2">{item.label}</a>
      ))}
    </div>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    
    menuBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });
    
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });
  });
</script>
