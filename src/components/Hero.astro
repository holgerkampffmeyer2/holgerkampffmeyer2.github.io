---
import type { ImageMetadata } from 'astro';
import { Picture } from 'astro:assets';

interface Props {
  image: string | ImageMetadata;
  id?: string;
  variant?: 'default' | 'secondary';
}
const { image, id, variant = 'default' } = Astro.props;
const overlayClass = variant === 'secondary' ? 'slide-overlay hero-overlay-secondary' : 'slide-overlay hero-overlay';
const isOptimized = typeof image !== 'string';
---
<section class="hero-slider" id={id}>
  <div class="slide active">
    <div class="slide-content">
      {isOptimized ? (
<Picture
        src={image}
        formats={['avif', 'webp']}
        alt="Hero image"
        loading="eager"
        fetchpriority="high"
        class="hero-bg-img"
        widths={[640, 1024, 1920]}
        sizes="100vw"
      />
      ) : (
        <img src={image} alt="Hero image" width="1920" height="1080" class="hero-bg-img" loading="eager" fetchpriority="high" />
      )}
      <div class={overlayClass}></div>
      <div class="container mx-auto px-4">
        <slot />
      </div>
    </div>
  </div>
</section>
