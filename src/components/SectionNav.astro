---
interface SectionLink {
  id: string;
  label: string;
}

interface Props {
  sections: SectionLink[];
}

const { sections } = Astro.props;
---

<div class="sticky top-20 z-40 bg-[var(--color-bg)]/90 backdrop-blur-md border-b border-[var(--color-border)]" data-section-nav>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 flex gap-4 sm:gap-8 overflow-x-auto scrollbar-hide py-2.5" aria-label="Section navigation">
    {sections.map(s => (
      <a href={`#${s.id}`} class="nav-link text-xs sm:text-sm whitespace-nowrap" data-section-link={s.id}>
        {s.label}
      </a>
    ))}
  </nav>
</div>

<script>
  (function () {
    var links = document.querySelectorAll("[data-section-link]");
    var sections = document.querySelectorAll("section[id]");
    var nav = document.querySelector("[data-section-nav]");
    if (!links.length || !sections.length) return;

    function updateActive(id) {
      links.forEach(function (link) {
        link.classList.toggle("active", link.getAttribute("data-section-link") === id);
      });
    }

    var observer = new IntersectionObserver(
      function (entries) {
        var visible = [];
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            visible.push({ id: entry.target.id, ratio: entry.intersectionRatio });
          }
        });
        if (visible.length === 0) return;
        visible.sort(function (a, b) { return b.ratio - a.ratio; });
        updateActive(visible[0].id);
      },
      { threshold: [0, 0.25, 0.5, 0.75, 1], rootMargin: "-80px 0px -40% 0px" }
    );

    sections.forEach(function (section) {
      observer.observe(section);
    });

    links.forEach(function (link) {
      link.addEventListener("click", function (e) {
        e.preventDefault();
        var id = link.getAttribute("data-section-link");
        var target = document.getElementById(id);
        if (target) {
          var top = target.getBoundingClientRect().top + window.scrollY - 90;
          window.scrollTo({ top: top, behavior: "smooth" });
        }
      });
    });
  })();
</script>
