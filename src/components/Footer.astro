---
import Icon from "./Icon.astro";
const currentYear = new Date().getFullYear();
---

<footer
  class="bg-[var(--color-surface)] border-t border-[var(--color-border)] py-12"
>
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <div>
        <h3 class="font-play text-xl font-bold mb-4">Holger Kampffmeyer</h3>
        <p class="text-[var(--color-text-muted)]">(DJ Hulk)</p>
<p class="text-[var(--color-text-muted)] mt-2">
           Meine Website für DJ-Dienstleistungen & Verleih: <a
             href="https://soundundlicht-stuttgart.de/"
             target="_blank"
             rel="noopener"
             class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium border border-[var(--color-primary)] rounded bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary)]/90 hover:text-white transition-colors"
           >
             Technik mieten
           </a>
         </p>
        <p class="text-[var(--color-text-muted)] mt-2">
          <a
            href="/rss.xml"
            class="inline-flex items-center gap-2 text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] transition-colors"
          >
            <Icon name="rss" class="h-5 w-5" />
            RSS Feed abonnieren
          </a>
        </p>
      </div>

      <div>
        <h4 class="font-bold mb-4">Links</h4>
        <ul class="space-y-2">
          <li>
            <a
              href="/vermietung"
              class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] transition-colors"
              >Vermietung</a>
          </li>
          <li>
            <a
              href="/djhulk-electronic-music"
              class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] transition-colors"
              >DJing</a>
          </li>
          <li>
            <a
              href="/work"
              class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] transition-colors"
              >Work</a>
          </li>
          <li>
            <a
              href="/impressum"
              rel="nofollow"
              class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] transition-colors"
              >Impressum</a>
          </li>
          <li>
            <a
              href="https://soundundlicht-stuttgart.de/"
              target="_blank"
              rel="noopener"
              class="text-[var(--color-text-muted)] hover:text-[var(--color-secondary)] transition-colors"
              >Sound & Licht Stuttgart →</a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="font-bold mb-4">Kontakt</h4>
        <div class="flex flex-col gap-2">
          <a
            href="mailto:holger.kampffmeyer+dj@gmail.com"
            class="inline-flex items-center justify-center px-3 py-1.5 text-sm font-medium border border-[var(--color-border)] rounded hover:bg-[var(--color-surface-hover)] transition-colors text-[var(--color-text-muted)] hover:text-[var(--color-secondary)]"
          >
            E-Mail senden
          </a>
        </div>
      </div>
    </div>

    <div
      class="border-t border-[var(--color-border)] pt-8 text-center text-[var(--color-text-muted)]"
    >
      <p>&copy; {currentYear} Holger Kampffmeyer. Alle Rechte vorbehalten.</p>
    </div>
  </div>
</footer>
