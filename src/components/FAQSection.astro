---
import Icon from "./Icon.astro";
const { faqs } = Astro.props;
---
<div class="mt-16">
  <h3 class="font-play text-2xl md:text-3xl font-bold text-center mb-10">
    Häufig gestellte Fragen (FAQ)
  </h3>
  <div class="max-w-3xl mx-auto space-y-4">
    {faqs.map((faq: any) => (
      <details class="bg-[var(--color-bg)] rounded-xl p-4 cursor-pointer group">
        <summary class="font-bold cursor-pointer flex items-center gap-3 list-none">
          <span class="w-6 h-6 bg-[var(--color-primary)]/20 rounded flex items-center justify-center text-[var(--color-primary)] group-open:rotate-90 transition-transform">
            <Icon name="chevron-right" class="w-3 h-3" />
          </span>
          {faq.question}
        </summary>
        <p class="text-[var(--color-text-muted)] mt-3 ml-9" set:html={faq.answer} />
      </details>
    ))}
  </div>
</div>
