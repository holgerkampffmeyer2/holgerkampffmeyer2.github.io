---
import '../styles/global.css';
import '../styles/fonts.css';
import { localBusinessJsonLd, siteNavigationJsonLd } from '../data/jsonLd';

interface Props {
  title: string;
  description?: string;
  image?: string;
  /** prevent indexing (e.g. legal pages) */
  noIndex?: boolean;
  /** additional JSON-LD objects to embed in head */
  jsonLd?: object | object[];
  /** image URL to preload for LCP (defaults to image) */
  preloadImage?: string;
  /** Open Graph type (default: website) */
  ogType?: string;
  /** OG image width (default: 1200) */
  ogImageWidth?: number;
  /** OG image height (default: 630) */
  ogImageHeight?: number;
  /** OG title override (falls back to title) */
  ogTitle?: string;
  /** suppress default LocalBusiness schema */
  noSiteJsonLd?: boolean;
  /** Twitter player URL (enables player card) */
  twitterPlayerUrl?: string;
  /** Twitter player width (default: 480) */
  twitterPlayerWidth?: number;
  /** Twitter player height (default: 480) */
  twitterPlayerHeight?: number;
}

const { 
  title, 
  description = "DJ Hulk aus Stuttgart. Electronic Music DJ für Events, Feiern und Hochzeiten. Wöchentliche DJ Mixes auf Mixcloud.",
  image = "/img/djhulk_logo.webp",
  noIndex = false,
  jsonLd,
  preloadImage,
  ogType = "website",
  ogImageWidth = 1200,
  ogImageHeight = 630,
  ogTitle,
  noSiteJsonLd,
  twitterPlayerUrl,
  twitterPlayerWidth = 480,
  twitterPlayerHeight = 480,
} = Astro.props;

let canonicalPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/index$/, '/');
// Ensure no trailing slash for trailingSlash: 'never' site
if (canonicalPath === '/') {
  // Homepage should have no path
  canonicalPath = '';
} else if (canonicalPath.endsWith('/')) {
  // Remove trailing slash for other pages
  canonicalPath = canonicalPath.slice(0, -1);
}
const canonicalURL = new URL(canonicalPath, Astro.site);
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Holger Kampffmeyer" />
    <meta name="keywords" content="Holger Kampffmeyer, DJ Hulk, Stuttgart, Mixcloud, DJ, House, Tech House, Drum n Bass" />
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0f" />
    <meta name="robots" content={noIndex ? "noindex, nofollow" : "index, follow"} />
    
    <title>{title}</title>
    
    {!noSiteJsonLd && (<>
    <!-- JSON-LD WebPage -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": title,
      "description": description,
      "url": canonicalURL.href,
      "mainEntity": {
        "@id": "https://holger-kampffmeyer.de/#dj"
      }
    })} />

    <!-- Schema.org LocalBusiness -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessJsonLd)} />

    <!-- JSON-LD SiteNavigationElement as ItemList -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(siteNavigationJsonLd)} />
    </>)}
    {jsonLd && (
      Array.isArray(jsonLd) ? jsonLd : [jsonLd]
    ).map(item => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    
    <!-- Theme: set data-theme via ?theme=<name> before paint -->
    <script is:inline>
      (function(){var m=window.location.search.match(/[?&]theme=(deep-bass|electric-night|golden-hour)(&|$)/);if(m)document.documentElement.setAttribute('data-theme',m[1]);})();
    </script>

    <!-- Theme CSS variables for all alt themes -->
    <style>
      html[data-theme="deep-bass"] {
        --color-bg: #050510;
        --color-surface: #0a1628;
        --color-surface-hover: #0f1f3a;
        --color-primary: #2563eb;
        --color-primary-hover: #3b82f6;
        --color-secondary: #1e40af;
        --color-secondary-hover: #2563eb;
        --color-accent: #60a5fa;
        --color-text: #f8fafc;
        --color-text-muted: #64748b;
        --color-border: #1e293b;
        --font-heading: 'Josefin Sans Variable', 'Josefin Sans', sans-serif;
        --font-body: 'Josefin Sans Variable', 'Josefin Sans', sans-serif;
      }
      html[data-theme="electric-night"] {
        --color-bg: #0a0a0f;
        --color-surface: #1c0a2e;
        --color-surface-hover: #2d1b4e;
        --color-primary: #a855f7;
        --color-primary-hover: #c084fc;
        --color-secondary: #ec4899;
        --color-secondary-hover: #f472b6;
        --color-accent: #22d3ee;
        --color-text: #f8fafc;
        --color-text-muted: #a1a1aa;
        --color-border: #3b0764;
        --font-heading: 'Josefin Sans Variable', 'Josefin Sans', sans-serif;
        --font-body: 'Josefin Sans Variable', 'Josefin Sans', sans-serif;
      }
      html[data-theme="golden-hour"] {
        --color-bg: #0a0a0f;
        --color-surface: #1a1410;
        --color-surface-hover: #35281e;
        --color-primary: #f59e0b;
        --color-primary-hover: #fbbf24;
        --color-secondary: #fb923c;
        --color-secondary-hover: #fdba74;
        --color-accent: #d97706;
        --color-text: #fefce8;
        --color-text-muted: #9a9490;
        --color-border: #292524;
        --font-heading: 'Josefin Sans Variable', 'Josefin Sans', sans-serif;
        --font-body: 'Josefin Sans Variable', 'Josefin Sans', sans-serif;
      }
    </style>

    <!-- Preload LCP image (use preloadImage if set, otherwise skip if image is only used for OG) -->
    {preloadImage && <link rel="preload" as="image" href={preloadImage} />}
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/josefin-sans-variable.woff2" />

    <!-- Preconnect to external origins -->
    <link rel="preconnect" href="https://www.mixcloud.com" crossorigin />
    <link rel="preconnect" href="https://www.youtube.com" crossorigin />
    <link rel="preconnect" href="https://www.google.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.mixcloud.com" />
    <link rel="dns-prefetch" href="https://www.youtube.com" />
    <link rel="dns-prefetch" href="https://www.google.com" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />
    <meta property="og:image:width" content={ogImageWidth.toString()} />
    <meta property="og:image:height" content={ogImageHeight.toString()} />
    <meta property="og:image:alt" content={ogTitle || "DJ Hulk - Holger Kampffmeyer"} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="DJ Hulk - Holger Kampffmeyer" />
    {ogType === "music.playlist" && <meta property="music:musician" content="https://www.mixcloud.com/holger-kampffmeyer/" />}
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content={twitterPlayerUrl ? "player" : "summary_large_image"} />
    <meta name="twitter:site" content="@djhulk_de" />
    <meta name="twitter:creator" content="@djhulk_de" />
    <meta name="twitter:title" content={ogTitle || title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).href} />
    {twitterPlayerUrl && <>
      <meta name="twitter:player" content={twitterPlayerUrl} />
      <meta name="twitter:player:width" content={twitterPlayerWidth.toString()} />
      <meta name="twitter:player:height" content={twitterPlayerHeight.toString()} />
    </>}
    
  </head>
  <body class="min-h-screen">
    <slot />
    <script src="/assets/animation-observer.js" defer is:inline></script>
  </body>
</html>
