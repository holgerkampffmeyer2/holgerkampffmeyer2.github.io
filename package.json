{
  "name": "holger-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/fetch-mixcloud.mjs && node scripts/fetch-mixcloud-blog.mjs && node scripts/generate-rss.mjs && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint src --ext .astro,.ts,.js && node scripts/check-paths.mjs",
    "lint:paths": "node scripts/check-paths.mjs",
    "lint:fix": "eslint src --ext .astro,.ts,.js --fix",
    "astro": "astro",
    "generate-rss": "node scripts/generate-rss.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.1.3",
    "node-fetch": "^3.3.2",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "astro-eslint-parser": "^1.3.0",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^17.4.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  }
