{
  "name": "holger-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:images": "node scripts/optimize-images.mjs",
    "build:seo": "node scripts/generate-rss.mjs && node scripts/generate-urllist.mjs",
    "build:full": "node scripts/fetch-mixcloud.mjs && node scripts/optimize-images.mjs && astro build && node scripts/generate-rss.mjs && node scripts/generate-urllist.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "NODE_OPTIONS=--max-old-space-size=1536 eslint src --ext .ts,.tsx,.astro --format json --cache --cache-location .eslintcache",
    "lint:fix": "NODE_OPTIONS=--max-old-space-size=1536 eslint src --fix --format json --cache --cache-location .eslintcache",
    "test": "vitest",
    "astro": "astro",
    "generate-rss": "node scripts/generate-rss.mjs",
    "generate-urllist": "node scripts/generate-urllist.mjs",
    "indexnow-submit": "node scripts/indexnow-submit.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^7.1.0",
    "node-fetch": "^3.3.2",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.4",
    "astro-eslint-parser": "^1.3.0",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^17.4.0",
    "playwright": "^1.61.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "yaml": "2.8.4"
  }
}